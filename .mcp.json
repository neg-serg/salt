      ],
      "env": {}
    },
    "color-convert": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-color-convert@latest"
      ],
      "env": {}
    },
    "openapi": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@reapi/mcp-openapi@latest"
      ],
      "env": {}
    },
    "wireshark": {
      "type": "stdio",
      "command": "/home/neg/.local/bin/uvx",
      "args": [
        "mcp-wireshark"
      ],
      "env": {}
    }
  }
}