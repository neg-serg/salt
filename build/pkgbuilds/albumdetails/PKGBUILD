# Maintainer: neg-serg <neg-serg@example.com>
pkgname=albumdetails
pkgver=0.1
pkgrel=1
pkgdesc='Generate details for music album'
arch=('x86_64')
url='https://github.com/neg-serg/albumdetails'
license=('MIT')
depends=('taglib')
makedepends=('gcc' 'make')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/master.tar.gz")
# Update hash after pushing to master: curl -sL ${url}/archive/master.tar.gz | sha256sum
sha256sums=('3ec67787ff7465c62c8defd984a40a5499620829d11c80fdb846a3a571987294')

build() {
    cd "${pkgname}-master"
    make
}

package() {
    cd "${pkgname}-master"
    make install DESTDIR="${pkgdir}" PREFIX=/usr
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
