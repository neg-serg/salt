# Maintainer: neg-serg <neg-serg@example.com>
pkgname=raise
pkgver=0.2.0
pkgrel=1
pkgdesc='Run or raise for Hyprland with --match regex support (neg-serg fork)'
arch=('x86_64')
url='https://github.com/neg-serg/raise'
license=('MIT')
depends=()
makedepends=('rust' 'cargo' 'git')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/master.tar.gz")
# Update hash after pushing to master: curl -sL ${url}/archive/master.tar.gz | sha256sum
sha256sums=('9d8e21ea3809387b88a2301ed95ab8db366fd416ca009ce6d7d47c783cb74332')

build() {
    cd "${pkgname}-master"
    cargo build --release
}

package() {
    cd "${pkgname}-master"
    install -Dm755 "target/release/raise" "${pkgdir}/usr/bin/raise"
}
