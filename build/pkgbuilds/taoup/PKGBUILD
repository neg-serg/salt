pkgname=taoup
pkgver=1.1.23
pkgrel=1
pkgdesc='The Art of Unix Programming wisdom quotes'
arch=('any')
url='https://github.com/globalcitizen/taoup'
license=('GPL-3.0-only')
depends=('ruby')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/v${pkgver}.tar.gz")
sha256sums=('0e6565f7eb9cc6dead61cd4748278dcf63e9d56a6fa6474c003758d986897e8e')

package() {
    cd "${pkgname}-${pkgver}"
    install -Dm755 taoup "${pkgdir}/usr/bin/taoup"
}
