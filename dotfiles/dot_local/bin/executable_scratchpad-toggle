#!/usr/bin/env zsh
# Toggle a hyprscratch scratchpad and fix position + size.
# Hyprland 0.54 ignores windowrule `move` for windows on special workspaces,
# so we apply movewindowpixel/resizewindowpixel after toggle once the client
# is discoverable.  This also prevents apps (e.g. Telegram) from overriding
# the desired size on their own.
#
# Usage: scratchpad-toggle <name>

local name=$1
[[ -z $name ]] && { print -u2 "usage: scratchpad-toggle <name>"; exit 1 }

# Desired positions (x y) per scratchpad — logical pixels for 1920x1080
typeset -A positions
positions=(
    amnezia  "960 32"
    im       "1340 20"
    music    "360 560"
    torrment "20 0"
    teardown "20 0"
    mixer    "1280 32"
)

# Desired sizes (w h) per scratchpad — must match hyprscratch.conf
typeset -A sizes
sizes=(
    amnezia  "960 860"
    im       "560 1020"
    music    "1200 480"
    torrment "1880 480"
    teardown "1880 560"
    mixer    "620 840"
)

hyprscratch toggle "$name"

# Only fix geometry if we have an override for this scratchpad.
local pos=${positions[$name]}
local sz=${sizes[$name]}
[[ -z $pos && -z $sz ]] && exit 0

# Read the scratchpad's class from config to find the window
local config=${XDG_CONFIG_HOME:-$HOME/.config}/hypr/hyprscratch.conf
local class=$(awk -v n="$name" '$0 ~ "^"n" \\{" {found=1} found && /class =/ {print $3; exit}' "$config")
[[ -z $class ]] && exit 0

# Wait briefly for the client to appear in hyprctl output on first spawn.
local addr=""
local attempt
for attempt in {1..10}; do
    addr=$(hyprctl clients -j | python3 -c "
import json, sys
for c in json.load(sys.stdin):
    if c['class'] == '$class':
        print(c['address'])
        break
" 2>/dev/null)
    [[ -n $addr ]] && break
    sleep 0.05
done

[[ -z $addr ]] && exit 0

# Enforce size first, then position — this prevents apps from overriding
# the desired geometry and keeps scratchpads consistent across toggles.
[[ -n $sz ]]  && hyprctl dispatch resizewindowpixel "exact ${=sz},address:$addr"
[[ -n $pos ]] && hyprctl dispatch movewindowpixel "exact ${=pos},address:$addr"
