#!/usr/bin/env zsh
# Toggle a hyprscratch scratchpad and fix position.
# Hyprland 0.54 ignores windowrule `move` for windows on special workspaces,
# so we apply movewindowpixel after toggle once the client is discoverable.
#
# Usage: scratchpad-toggle <name>

local name=$1
[[ -z $name ]] && { print -u2 "usage: scratchpad-toggle <name>"; exit 1 }

# Desired positions (x y) per scratchpad — scaled pixels for 1920x1080
typeset -A positions
positions=(
    im      "1334 10"
    music   "288 540"
)

hyprscratch toggle "$name"

# Only fix position if we have an override for this scratchpad.
local pos=${positions[$name]}
[[ -z $pos ]] && exit 0

# Read the scratchpad's class from config to find the window
local config=${XDG_CONFIG_HOME:-$HOME/.config}/hypr/hyprscratch.conf
local class=$(awk -v n="$name" '$0 ~ "^"n" \\{" {found=1} found && /class =/ {print $3; exit}' "$config")
[[ -z $class ]] && exit 0

# Wait briefly for the client to appear in hyprctl output on first spawn.
local addr=""
local attempt
for attempt in {1..10}; do
    addr=$(hyprctl clients -j | python3 -c "
import json, sys
for c in json.load(sys.stdin):
    if c['class'] == '$class':
        print(c['address'])
        break
" 2>/dev/null)
    [[ -n $addr ]] && break
    sleep 0.05
done

# Hidden scratchpads still keep their client address, so applying the move here
# is harmless and ensures the next reveal also lands in the expected position.
[[ -n $addr ]] && hyprctl dispatch movewindowpixel "exact ${=pos},address:$addr"
