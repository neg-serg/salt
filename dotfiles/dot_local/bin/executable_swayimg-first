#!/usr/bin/env zsh
# swayimg-first: session manager for swayimg
# - Uses fd for fast directory expansion (ignores .git by default)
# - Passes file list via --from-file for large directories
# - Manages session metadata for swayimg-actions.sh
# - Cleans up stale session files from crashed sessions

data_dir="${XDG_DATA_HOME:-$HOME/.local/share}/swayimg"
mkdir -p "$data_dir"

# Clean stale session files older than 24 hours
find "$data_dir" \( -name 'swayimg-*.list' -o -name 'swayimg-*.range' \) -mtime +1 -delete 2>/dev/null || true

# Session metadata — files created lazily by action scripts if needed
session_id="swayimg-$PPID-$$-$RANDOM"
export SWAYIMG_SESSION_ID="$session_id"
export SWAYIMG_FILELIST="$data_dir/${session_id}.list"
export SWAYIMG_RANGE_FILE="$data_dir/${session_id}.range"

# Classify arguments into files, directories, and flags
files=()
dirs=()
flags=()
had_explicit_args=false

for arg in "$@"; do
  if [[ "$arg" == -* ]]; then
    flags+=("$arg")
  elif [[ -d "$arg" ]]; then
    dirs+=("$arg")
    had_explicit_args=true
  elif [[ -f "$arg" ]]; then
    files+=("$arg")
    had_explicit_args=true
  else
    print -u2 "sx: skipping non-existent path: $arg"
    had_explicit_args=true
  fi
done

# Error if user gave paths but none were valid
if $had_explicit_args && (( ${#files[@]} + ${#dirs[@]} == 0 )); then
  print -u2 "sx: no valid files or directories to open"
  exit 1
fi

# Expand directories via fd (fast, ignores .git/VCS by default)
# Write to --from-file for large lists to avoid ARG_MAX
filelist="$data_dir/${session_id}.from"
: > "$filelist"

for dir in "${dirs[@]}"; do
  fd -t f . "$dir" >> "$filelist" 2>/dev/null
done

for file_arg in "${files[@]}"; do
  print -r -- "$file_arg" >> "$filelist"
done

# Check if we have anything to show
if [[ ! -s "$filelist" ]] && ! $had_explicit_args; then
  # No args given — let swayimg use CWD
  rm -f "$filelist"
  swayimg "${flags[@]}"
  rc=$?
elif [[ ! -s "$filelist" ]]; then
  print -u2 "sx: no images found"
  rm -f "$filelist"
  exit 1
else
  swayimg "${flags[@]}" --from-file "$filelist"
  rc=$?
fi

# Cleanup
rm -f "$filelist" "$SWAYIMG_FILELIST" "$SWAYIMG_RANGE_FILE" 2>/dev/null || true
exit $rc
