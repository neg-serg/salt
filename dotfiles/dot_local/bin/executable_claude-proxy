#!/usr/bin/env zsh
setopt ERR_EXIT NO_UNSET PIPE_FAIL

# Isolated Claude Code instance routed through ProxyPilot.
# Uses a separate config dir so it can never touch ~/.claude/.

CLAUDE_PROXY_URL=${CLAUDE_PROXY_URL:-http://127.0.0.1:8317}
CLAUDE_PROXY_CONFIG=${CLAUDE_PROXY_CONFIG:-${HOME}/.claude-proxy}

if [[ -z ${PROXYPILOT_API_KEY:-} ]]; then
  print -u2 -- "PROXYPILOT_API_KEY is not set; run chezmoi apply or source secrets first."
  exit 1
fi

if ! command -v claude >/dev/null 2>&1; then
  print -u2 -- "claude CLI is not installed or not on PATH."
  exit 1
fi

mkdir -p "${CLAUDE_PROXY_CONFIG}"

exec env \
  CLAUDE_CONFIG_DIR="${CLAUDE_PROXY_CONFIG}" \
  ANTHROPIC_BASE_URL="${CLAUDE_PROXY_URL}" \
  ANTHROPIC_API_KEY="${PROXYPILOT_API_KEY}" \
  claude "$@"
