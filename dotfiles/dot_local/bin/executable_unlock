#!/usr/bin/env zsh
# unlock: add SSH key to agent, passphrase from gopass
# Usage: unlock

set -e

cleanup() { rm -f "$_askpass"; unset _pp 2>/dev/null || true; }
trap cleanup EXIT HUP INT TERM

# Ensure hashed socket symlinks exist (GnuPG 2.4+ with XDG GNUPGHOME)
_hash_dir="${XDG_RUNTIME_DIR}/gnupg/d.arw7zqof5jnud6ggibnucipd"
if [ ! -d "$_hash_dir" ]; then
    systemd-tmpfiles --user --create 2>/dev/null || true
fi

# Ensure gpg-agent is ready (provides SSH via enable-ssh-support)
# --no-autostart prevents spawning a rogue --daemon agent that conflicts with systemd
gpg-connect-agent --no-autostart updatestartuptty /bye >/dev/null 2>&1 || true
: "${SSH_AUTH_SOCK:=$(gpgconf --list-dirs agent-ssh-socket)}"
export SSH_AUTH_SOCK

# Skip if key already loaded
_fp="$(ssh-keygen -lf "$HOME/.ssh/id_ed25519" 2>/dev/null | awk '{print $2}')"
if [ -n "$_fp" ] && ssh-add -l 2>/dev/null | grep -qF "$_fp"; then
    echo "key already loaded"
    exit 0
fi

# Retrieve passphrase (pinentry handles GPG/Yubikey interaction)
_pp="$(gopass show -o ssh-key)"

# Temporary askpass helper — avoids expect dependency
_askpass="$(mktemp)"
chmod 700 "$_askpass"
cat > "$_askpass" << 'EOF'
#!/bin/sh
echo "$UNLOCK_PP"
EOF

# Add key
UNLOCK_PP="$_pp" SSH_ASKPASS="$_askpass" SSH_ASKPASS_REQUIRE=force \
    ssh-add "$HOME/.ssh/id_ed25519" </dev/null
