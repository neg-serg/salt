#!/usr/bin/env zsh
# vol: adjust PipeWire default sink volume via wpctl
# Usage: vol [+DELTA|-DELTA]
#   Example: vol +0.05 (increase), vol -0.05 (decrease)

IFS=$'\n\t'
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || -z "${1:-}" ]]; then
  sed -n '2,4p' "$0" | sed 's/^# \{0,1\}//'; exit 0
fi

command -v wpctl >/dev/null 2>&1 || { print -u2 'vol: wpctl not found'; :; }

sign(){
  case "$1" in
    -*) echo '-' ;;
    +*) echo '+' ;;
    *) echo '' ;;
  esac
}
set_volume(){ wpctl set-volume @DEFAULT_SINK@ "$1" }
set_volume_safe(){
    # Clamp to [0.00, 1.00] — pure zsh arithmetic, 1 fork (wpctl) instead of 5
    local raw=$(wpctl get-volume @DEFAULT_SINK@)
    raw=${raw#*: }; raw=${raw%% *}
    local -F 2 v
    (( v = raw + $1 ))
    (( v > 1.0 )) && v=1.00
    (( v < 0.0 )) && v=0.00
    set_volume "$v"
}

case "$(sign "$1")" in
  '-') set_volume "$1" ;;
  '+') set_volume_safe "$1" ;;
   *) print -u2 'vol: expected +DELTA or -DELTA'; exit 2 ;;
esac
