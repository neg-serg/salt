#!/usr/bin/env zsh
# Audio sink switcher for PipeWire/WirePlumber
# Based on hyprland-sink-switcher, adapted for rofi + notify-send

ALLOWED_SINKS=(rme-genelec rme-headphones)

get_sinks() {
    local all sink
    all=(${(f)"$(pactl list sinks short | awk '{print $2}')"})
    for sink in "${all[@]}"; do
        (( ${ALLOWED_SINKS[(Ie)$sink]} )) && print -- "$sink"
    done
}

get_default_sink() { pactl info | awk '/Default Sink:/{print $3}'; }

friendly_name() {
    pactl list sinks | awk -v sink="$1" '
        $1=="Name:" && $2==sink {found=1}
        found && /Description:/ {sub(/.*Description: /,""); print; exit}
    '
}

set_sink() {
    local sink="$1"
    # Restore hardware link chain first. PipeWire's policy does not auto-bind
    # the AUX2..AUX7 ports of the RME loopbacks to the hardware node (only
    # FL/FR positions get default routing), so without this step switching to
    # rme-genelec (AUX4/5) or rme-headphones (AUX2/3) silently drops audio.
    # pw-restore-links is idempotent — it no-ops when everything is already wired.
    if command -v pw-restore-links >/dev/null 2>&1; then
        pw-restore-links >/dev/null 2>&1 || true
    fi
    pactl set-default-sink "$sink"
    # Move application streams to the new sink (skip PipeWire loopback internals)
    pactl -f json list sink-inputs \
        | jq -r '.[] | select(.properties["node.name"] | test("^output\\.loopback") | not) | .index' \
        | while read -r input; do
        pactl move-sink-input "$input" "$sink"
    done
    notify-send -t 2000 -h string:x-canonical-private-synchronous:sink-switch \
        "Audio Output" "$(friendly_name "$sink")"
}

cycle() {
    local direction="$1"
    local -a sinks
    sinks=("${(@f)$(get_sinks)}")
    local current idx=0
    current=$(get_default_sink)
    for i in {1..${#sinks[@]}}; do
        [[ "${sinks[$i]}" == "$current" ]] && idx=$i && break
    done
    (( idx == 0 )) && return 1
    local count=${#sinks[@]}
    local new_idx
    if [[ "$direction" == "next" ]]; then
        new_idx=$(( (idx % count) + 1 ))
    else
        new_idx=$(( ((idx - 2 + count) % count) + 1 ))
    fi
    set_sink "${sinks[$new_idx]}"
}

select_sink() {
    local current menu=""
    current=$(get_default_sink)
    declare -A name_to_sink
    while read -r sink; do
        local name
        name=$(friendly_name "$sink")
        [[ -z "$name" ]] && name="$sink"
        name_to_sink["$name"]="$sink"
        if [[ "$sink" == "$current" ]]; then
            menu+="* ${name}\n"
        else
            menu+="  ${name}\n"
        fi
    done < <(get_sinks)
    local chosen
    chosen=$(printf '%b' "$menu" | vicinae dmenu --placeholder "Audio Sink" | sed 's/^[* ] //')
    [[ -z "$chosen" ]] && return
    local target="${name_to_sink[$chosen]}"
    [[ -n "$target" ]] && set_sink "$target"
}

case "${1:-}" in
    next)   cycle next ;;
    prev)   cycle prev ;;
    select) select_sink ;;
    *)      echo "Usage: ${0##*/} {next|prev|select}" >&2; exit 1 ;;
esac
