#!/usr/bin/env zsh
# pinentry-rofi — GPG pinentry with rofi-first, TTY opt-in
# Implements the Assuan pinentry protocol over stdin/stdout.
# Default: rofi GUI prompt (safe for pipe/subprocess/IDE callers).
# TTY opt-in: set PINENTRY_USER_DATA=force-tty before gpg call.
# Headless/SSH: falls back to pinentry-curses when no display.
# Injects Wayland/DBus env vars for gpg-agent socket activation.

# --- Env injection (gpg-agent starts before GUI is up) ---
if [ -z "$WAYLAND_DISPLAY" ] && [ -n "$XDG_RUNTIME_DIR" ]; then
    wayland_socket=$(find "$XDG_RUNTIME_DIR" -maxdepth 1 -name 'wayland-*' ! -name '*.lock' -print -quit 2>/dev/null)
    if [ -n "$wayland_socket" ]; then
        export WAYLAND_DISPLAY
        WAYLAND_DISPLAY=$(basename "$wayland_socket")
    fi
fi

if [ -z "$DISPLAY" ] && [ -n "$WAYLAND_DISPLAY" ]; then
    export DISPLAY=:0
fi

if [ -z "$DBUS_SESSION_BUS_ADDRESS" ] && [ -n "$XDG_RUNTIME_DIR" ] && [ -S "$XDG_RUNTIME_DIR/bus" ]; then
    export DBUS_SESSION_BUS_ADDRESS="unix:path=$XDG_RUNTIME_DIR/bus"
fi

# --- Last resort: no rofi AND no display ---
if ! command -v rofi >/dev/null 2>&1 || { [ -z "$WAYLAND_DISPLAY" ] && [ -z "$DISPLAY" ]; }; then
    for fb in pinentry-gnome3 pinentry-curses pinentry-tty; do
        if command -v "$fb" >/dev/null 2>&1; then
            exec "$fb" "$@"
        fi
    done
fi

# --- Assuan pinentry protocol ---
desc="" title="GPG" error="" tty_name="" tty_type="" user_data=""

# ask_pin_tty: prompt for PIN on the agent's TTY
# Returns pin via stdout, exit 1 on cancel/failure
ask_pin_tty() {
    local tty=$1 prompt=$2 err=$3
    {
        [[ -n "$err" ]] && printf '\033[31m%s\033[0m\n' "$err"
        [[ -n "$desc" ]] && printf '%s\n' "$desc"
        printf '%s ' "${prompt:-PIN:}"
    } > "$tty"
    # Read PIN with echo disabled
    local pin=""
    if IFS= read -rs pin < "$tty"; then
        printf '\n' > "$tty"
        printf '%s' "$pin"
        return 0
    fi
    printf '\n' > "$tty"
    return 1
}

# confirm_tty: yes/no prompt on the agent's TTY
confirm_tty() {
    local tty=$1 prompt=$2 mesg=$3
    {
        [[ -n "$mesg" ]] && printf '%s\n' "$mesg"
        printf '%s [y/N] ' "${prompt:-Confirm}"
    } > "$tty"
    local answer=""
    IFS= read -r answer < "$tty"
    [[ "$answer" == [yY]* ]]
}

# has_valid_tty: check if TTY should be used for PIN entry
# Default: rofi (safe for any caller). TTY only via explicit opt-in
# (PINENTRY_USER_DATA=force-tty passed through gpg-agent Assuan protocol).
has_valid_tty() {
    [[ "$user_data" == *force-tty* ]] || return 1
    [[ -n "$tty_name" ]] && [[ -c "$tty_name" ]] && [[ -w "$tty_name" ]]
}

echo "OK Pleased to meet you"

while IFS= read -r line; do
    cmd="${line%% *}"
    arg="${line#* }"
    [ "$cmd" = "$arg" ] && arg=""

    case "$cmd" in
        SETDESC)
            desc=$(echo "$arg" | sed 's/%0A/\n/g; s/%25/%/g; s/<[^>]*>//g')
            echo "OK" ;;
        SETPROMPT)
            echo "OK" ;;
        SETTITLE)
            title="$arg"
            echo "OK" ;;
        SETERROR)
            error="$arg"
            echo "OK" ;;
        OPTION)
            case "$arg" in
                ttyname=*) tty_name="${arg#ttyname=}" ;;
                ttytype=*) tty_type="${arg#ttytype=}" ;;
                pinentry-user-data=*) user_data="${arg#pinentry-user-data=}" ;;
            esac
            echo "OK" ;;
        SETOK|SETCANCEL|SETNOTOK|SETQUALITYBAR|SETQUALITYBAR_TT)
            echo "OK" ;;
        GETPIN)
            if has_valid_tty; then
                # TTY path: prompt directly in the terminal
                pin=$(ask_pin_tty "$tty_name" "$title:" "$error")
                if [ $? -eq 0 ] && [ -n "$pin" ]; then
                    echo "D $pin"
                    echo "OK"
                else
                    echo "ERR 83886179 Operation cancelled"
                fi
            else
                # GUI path: rofi
                pin=$(rofi -dmenu -password -no-fixed-num-lines \
                    -p "" -theme askpass \
                    -l 0 < /dev/null 2>/dev/null)
                if [ $? -eq 0 ] && [ -n "$pin" ]; then
                    echo "D $pin"
                    echo "OK"
                else
                    echo "ERR 83886179 Operation cancelled"
                fi
            fi
            error="" ;;
        CONFIRM)
            if has_valid_tty; then
                if confirm_tty "$tty_name" "$title" "$desc"; then
                    echo "OK"
                else
                    echo "ERR 83886179 Operation cancelled"
                fi
            else
                result=$(printf "Yes\nNo" | rofi -dmenu -p "$title" -mesg "$desc" \
                    -theme-str 'window {width: 25%;}' 2>/dev/null)
                if [ "$result" = "Yes" ]; then
                    echo "OK"
                else
                    echo "ERR 83886179 Operation cancelled"
                fi
            fi ;;
        GETINFO)
            case "$arg" in
                pid) echo "D $$"; echo "OK" ;;
                flavor) echo "D rofi"; echo "OK" ;;
                version) echo "D 0.2"; echo "OK" ;;
                ttyinfo) echo "D - - -"; echo "OK" ;;
                *) echo "OK" ;;
            esac ;;
        BYE)
            echo "OK closing connection"
            exit 0 ;;
        *)
            echo "OK" ;;
    esac
done
