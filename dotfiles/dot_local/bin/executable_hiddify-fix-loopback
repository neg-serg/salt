#!/usr/bin/env zsh
set -eu

cfg="$HOME/.local/share/app.hiddify.com/data/current-config.json"
if [ -f "$cfg" ] && command -v jq >/dev/null 2>&1; then
  tmp="$(mktemp)"
  if jq '
    if (.inbounds | type) == "array" then
      .inbounds |= map(
        select(
          ((.listen // "") != "::1") and
          ((.listen // "") != "[::1]") and
          ((.tag // "") | endswith("::1") | not)
        )
      )
    else
      .
    end
  ' "$cfg" >"$tmp"; then
    mv "$tmp" "$cfg"
  else
    rm -f "$tmp"
    exit 1
  fi
fi

kioslaverc="$HOME/.config/kioslaverc"
if [ -f "$kioslaverc" ]; then
  sed -i 's#\[::1\]:12334#127.0.0.1:12334#g' "$kioslaverc"
  sed -i 's#\[::1\]:12335#127.0.0.1:12335#g' "$kioslaverc"
  sed -i 's#\[::1\]:12336#127.0.0.1:12336#g' "$kioslaverc"
  sed -i 's#\[::1\]:12337#127.0.0.1:12337#g' "$kioslaverc"
fi
