#!/usr/bin/env zsh
set -eu

cfg="$HOME/.local/share/app.hiddify.com/data/current-config.json"
if [ -f "$cfg" ] && command -v jq >/dev/null 2>&1; then
  tmp="$(mktemp)"
  if jq '.inbounds |= map(select(.listen != "::1"))' "$cfg" >"$tmp"; then
    mv "$tmp" "$cfg"
  else
    rm -f "$tmp"
    exit 1
  fi
fi

kioslaverc="$HOME/.config/kioslaverc"
if [ -f "$kioslaverc" ]; then
  sed -i 's#\[::1\]:12334#127.0.0.1:12334#g' "$kioslaverc"
fi
