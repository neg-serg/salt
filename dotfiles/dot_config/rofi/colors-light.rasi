    secondary-fixed-dim: #c6c4dd;
    on-secondary: #ffffff;
    on-secondary-fixed: #1a1a2c;
    on-secondary-fixed-variant: #454559;
    secondary-container: #e2e0f9;
    on-secondary-container: #1a1a2c;
    tertiary: #7a5369;
