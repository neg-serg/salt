# ── Keybindings (ported from kitty key.conf) ──────────────────────────
# Reset defaults, build from scratch
keybind = clear

# Paste
keybind = insert=paste_from_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Scrollback prompt navigation
keybind = ctrl+shift+z=jump_to_prompt:-1
keybind = ctrl+shift+x=jump_to_prompt:1

# Tabs
keybind = ctrl+shift+alt+t=prompt_tab_title
keybind = ctrl+shift+comma=move_tab:-1
keybind = ctrl+shift+period=move_tab:1
keybind = ctrl+shift+q=close_tab:this
keybind = ctrl+arrow_left=previous_tab
keybind = ctrl+arrow_right=next_tab
keybind = alt+n=new_tab

# Font size
keybind = ctrl+equal=increase_font_size:0.5
keybind = ctrl+minus=decrease_font_size:0.5
keybind = ctrl+0=reset_font_size

# Splits / windows
keybind = ctrl+shift+right_bracket=goto_split:next
keybind = ctrl+shift+left_bracket=goto_split:previous
keybind = ctrl+shift+w=close_surface

# Config
keybind = ctrl+shift+r>r=reload_config

# Copy/paste
keybind = ctrl+shift+c=copy_to_clipboard:mixed
