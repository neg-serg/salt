# Ghostty config — ported from kitty for feature parity
# vim:ft=ini

# ── Font ──────────────────────────────────────────────────────────────
font-family = Iosevka Medium
font-family-bold = Iosevka Bold
font-family-italic = Iosevka Italic
font-family-bold-italic = Iosevka Bold Italic
font-size = 13
font-thicken = false
# Nerd Font symbols — Ghostty auto-detects fallback, but explicit map
# ensures the same glyphs kitty uses via symbol_map
font-codepoint-map = U+F313,U+E21E,U+E256,U+E271,U+F440,U+F410,U+F43A,U+E610,U+E7AF,U+F1DA=Fira Code Nerd Font Mono
# Match kitty undercurl_style thin-dense
adjust-underline-thickness = 2
adjust-cursor-thickness = 2

# ── Performance (maximum) ─────────────────────────────────────────────
# No vsync: uncapped frame rate, lowest input latency
window-vsync = false

# ── Cursor ────────────────────────────────────────────────────────────
cursor-color = #4842ff
cursor-text = #000000
cursor-style = block
cursor-style-blink = false
cursor-opacity = 1

# ── Scrollback ────────────────────────────────────────────────────────
scrollback-limit = 4000

# ── Mouse / selection ─────────────────────────────────────────────────
copy-on-select = clipboard
mouse-hide-while-typing = true
mouse-scroll-multiplier = 5
focus-follows-mouse = false

# ── URL handling ──────────────────────────────────────────────────────
link-url = true

# ── Window ────────────────────────────────────────────────────────────
window-padding-x = 2
window-padding-y = 2
window-padding-balance = true
window-padding-color = background
window-decoration = server
confirm-close-surface = false
resize-overlay = never
window-inherit-working-directory = true
window-inherit-font-size = true

# ── Background / transparency ─────────────────────────────────────────
# Match kitty: background_opacity 0.88, background #000000
background-opacity = 0.88
# Blur behind transparent areas (Hyprland supports this natively)
background-blur = true

# ── Shell integration ─────────────────────────────────────────────────
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# ── Clipboard ─────────────────────────────────────────────────────────
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = false

# ── Tab bar ───────────────────────────────────────────────────────────
gtk-tabs-location = bottom

