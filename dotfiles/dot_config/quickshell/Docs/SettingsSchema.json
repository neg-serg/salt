{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/quickshell/Settings.schema.json",
  "title": "Quickshell Settings",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "weatherCity": { "type": "string", "default": "Saint Petersburg", "description": "City for weather widget" },
    "userAgent": { "type": "string", "default": "NegPanel", "description": "HTTP User-Agent string" },

    "debugLogs": { "type": "boolean", "default": false, "description": "Enable low-importance debug logs" },
    "debugNetwork": { "type": "boolean", "default": false, "description": "Enable extra network debug logs" },
    "strictThemeTokens": { "type": "boolean", "default": false, "description": "Warn on missing/deprecated Theme tokens" },
    "reducedMotion": { "type": "boolean", "default": false, "description": "Disable non-essential animations (accessibility)" },

    "useFahrenheit": { "type": "boolean", "default": false, "description": "Use Fahrenheit temperatures" },
    "showMediaInBar": { "type": "boolean", "default": false, "description": "Show media block in bar" },
    "showWeatherInBar": { "type": "boolean", "default": true, "description": "Show weather capsule in bar" },

    "reverseDayMonth": { "type": "boolean", "default": false, "description": "Flip day and month order" },
    "use12HourClock": { "type": "boolean", "default": false, "description": "12-hour time format" },
    "fontSizeMultiplier": { "type": "number", "default": 1.0, "minimum": 0.5, "maximum": 2.5, "description": "Global font size multiplier" },

    "panelBgAlphaScale": { "type": "number", "default": 0.2, "minimum": 0, "maximum": 1, "description": "Panel background alpha multiplier (0 = transparent, 1 = opaque)" },
    "enableWedgeClipShader": { "type": "boolean", "default": false, "description": "Enable wedge clip ShaderEffect path" },

    "mediaIconStretchMode": { "type": "string", "default": "compact", "enum": ["compact", "stretch", "panel"], "description": "Media icon display mode" },
    "mediaIconMinWidthPx": { "type": "integer", "default": 0, "minimum": 0, "description": "Media icon minimum width (0 = auto)" },
    "mediaIconMaxWidthPx": { "type": "integer", "default": 0, "minimum": 0, "description": "Media icon maximum width (0 = unlimited)" },
    "mediaIconPreferredWidthPx": { "type": "integer", "default": 0, "minimum": 0, "description": "Media icon preferred width (0 = auto)" },
    "mediaIconStretchShare": { "type": "number", "default": 1.0, "minimum": 0, "maximum": 1, "description": "Fraction of available space for stretched media icon" },
    "mediaIconOverlayPaddingPx": { "type": "integer", "default": 0, "minimum": 0, "description": "Padding around media icon overlay" },
    "mediaIconPanelOverlayPaddingPx": { "type": "integer", "default": 12, "minimum": 0, "description": "Padding around panel-mode media overlay" },
    "mediaIconPanelOverlayWidthShare": { "type": "number", "default": 0.45, "minimum": 0, "maximum": 1, "description": "Width share of panel overlay relative to icon" },
    "mediaIconPanelOverlayBgOpacity": { "type": "number", "default": 0.65, "minimum": 0, "maximum": 1, "description": "Panel overlay background opacity" },
    "mediaIconBorderless": { "type": "boolean", "default": false, "description": "Render media capsule without borders/contrasting background" },

    "mediaPanelButtonBorderless": { "type": "boolean", "default": true, "description": "Remove panel-mode play/pause button border" },
    "mediaPanelButtonLargerIcon": { "type": "boolean", "default": true, "description": "Prefer enlarged borderless button in panel mode" },

    "hideSystemTrayCapsule": { "type": "boolean", "default": true, "description": "Hide inline tray capsule (hover menu still accessible)" },
    "systemTrayTightSpacing": { "type": "boolean", "default": true, "description": "Align inline tray contents flush with capsule edges" },

    "cavaBars": { "type": "integer", "default": 86, "minimum": 8, "maximum": 512, "description": "CAVA bars count" },
    "cavaFramerate": { "type": "integer", "default": 24, "minimum": 1, "description": "CAVA framerate (FPS)" },
    "cavaMonstercat": { "type": "boolean", "default": false },
    "cavaGravity": { "type": "integer", "default": 150000, "description": "CAVA decay/gravity constant" },
    "cavaNoiseReduction": { "type": "integer", "default": 12, "description": "CAVA noise reduction level" },
    "spectrumUseGradient": { "type": "boolean", "default": false, "description": "Use gradient fill" },
    "spectrumMirror": { "type": "boolean", "default": false, "description": "Mirror spectrum bars" },
    "showSpectrumTopHalf": { "type": "boolean", "default": false, "description": "Render top half only" },
    "spectrumFillOpacity": { "type": "number", "default": 0.35, "minimum": 0, "maximum": 1, "description": "Fill opacity" },
    "spectrumHeightFactor": { "type": "number", "default": 1.2, "minimum": 0.1, "maximum": 5, "description": "Height relative to text size" },
    "spectrumOverlapFactor": { "type": "number", "default": 0.2, "minimum": 0, "maximum": 1, "description": "Overlap with text area" },
    "spectrumBarGap": { "type": "number", "default": 1.0, "minimum": 0, "maximum": 10, "description": "Gap between bars (logical px)" },
    "spectrumVerticalRaise": { "type": "number", "default": 0.75, "description": "Vertical offset" },

    "activeVisualizerProfile": { "type": "string", "default": "classic" },
    "visualizerProfiles": {
      "type": "object",
      "default": { "classic": {} },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "cavaBars": { "type": "integer", "minimum": 2 },
          "cavaFramerate": { "type": "integer", "minimum": 1 },
          "cavaMonstercat": { "type": "boolean" },
          "cavaGravity": { "type": "integer" },
          "cavaNoiseReduction": { "type": "integer" },
          "spectrumFillOpacity": { "type": "number", "minimum": 0, "maximum": 1 },
          "spectrumHeightFactor": { "type": "number", "minimum": 0.1, "maximum": 5 },
          "spectrumOverlapFactor": { "type": "number", "minimum": 0, "maximum": 1 },
          "spectrumBarGap": { "type": "number", "minimum": 0 },
          "spectrumVerticalRaise": { "type": "number" },
          "spectrumMirror": { "type": "boolean" }
        }
      },
      "description": "Named set of visualizer profiles"
    },

    "timeBracketStyle": {
      "type": "string",
      "default": "round",
      "enum": ["round","square","lenticular","lenticular_black","angle","tortoise"],
      "description": "Bracket style used in RichText"
    },

    "barMonitors": { "type": "array", "items": { "type": "string" }, "default": [] },
    
    "monitorScaleOverrides": {
      "type": "object",
      "default": {},
      "additionalProperties": { "type": "number", "minimum": 0.25, "maximum": 4 },
      "description": "Per-screen UI scale keyed by Screen.name"
    },

    "collapseSystemTray": { "type": "boolean", "default": true },
    "collapsedTrayIcon": { "type": "string", "default": "expand_more" },
    "trayFallbackIcon": { "type": "string", "default": "broken_image" },

    "contrastThreshold": { "type": "number", "default": 0.5, "minimum": 0, "maximum": 1, "description": "Threshold for light/dark text selection" },
    "contrastWarnRatio": { "type": "number", "default": 4.5, "minimum": 1, "description": "Target contrast ratio for warnings" },

    "pinnedPlayers": { "type": "array", "items": { "type": "string" }, "default": [] },
    "ignoredPlayers": { "type": "array", "items": { "type": "string" }, "default": [] },


    "showMediaVisualizer": { "type": "boolean", "default": false },

    "playerSelectionPriority": {
      "type": "array",
      "default": ["mpdPlaying","anyPlaying","mpdRecent","recent","manual","first"],
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["mpdPlaying","anyPlaying","mpdRecent","recent","manual","first"] }
    },
    "playerSelectionPreset": { "type": "string", "default": "default" },

    "musicPopupWidth": { "type": "integer", "default": 840, "minimum": 200, "description": "Media popup width (logical px)" },
    "musicPopupHeight": { "type": "integer", "default": 250, "minimum": 120, "description": "Media popup height (logical px)" },
    "musicPopupPadding": { "type": "integer", "default": 12, "minimum": 0, "description": "Media popup inner padding" },
    "musicPopupEdgeMargin": { "type": "integer", "default": 4, "minimum": 0, "description": "Horizontal margin between popup and screen edge (logical px)" },

    "networkPingIntervalMs": { "type": "integer", "default": 30000, "minimum": 1000, "maximum": 600000, "description": "Network ping interval (ms)" },
    "networkPingTarget": { "type": "string", "default": "8.8.8.8", "description": "Host to ping for internet reachability check" },
    "networkNoInternetColor": { "type": "string", "default": "#FF6E00", "description": "No-internet status color" },
    "networkNoLinkColor": { "type": "string", "default": "#D81B60", "description": "No-link status color" },

    "showCpuMonitor": { "type": "boolean", "default": true, "description": "Show CPU usage in system monitor capsule" },
    "showRamMonitor": { "type": "boolean", "default": true, "description": "Show RAM usage in system monitor capsule" },
    "showIoMonitor": { "type": "boolean", "default": true, "description": "Show disk I/O in system monitor capsule" },
    "showGpuMonitor": { "type": "boolean", "default": true, "description": "Show GPU usage in system monitor capsule" },
    "showTempMonitor": { "type": "boolean", "default": true, "description": "Show CPU temperature in system monitor capsule" },
    "showSwapMonitor": { "type": "boolean", "default": true, "description": "Show swap usage in system monitor capsule" },
    "systemMonitorPollMs": { "type": "integer", "default": 2000, "minimum": 500, "maximum": 60000, "description": "System monitor polling interval (ms)" },
    "systemMonitorIoMaxMiBps": { "type": "integer", "default": 500, "minimum": 10, "maximum": 10000, "description": "Disk I/O reference max for bar normalization (MiB/s)" },
    "systemMonitorHideIdle": { "type": "boolean", "default": true, "description": "Hide metric icon+bar when value is below idle threshold" },
    "systemMonitorIdleThreshold": { "type": "number", "default": 0.03, "minimum": 0, "maximum": 0.5, "description": "Threshold below which idle metrics are hidden (0.03 = 3%)" },
    "systemMonitorBarWidth": { "type": "integer", "default": 3, "minimum": 1, "maximum": 10, "description": "Bar width in logical pixels" },
    "systemMonitorIconScale": { "type": "number", "default": 0.85, "minimum": 0.3, "maximum": 1.5, "description": "Icon size as fraction of capsule inner height" },
    "systemMonitorSpacing": { "type": "integer", "default": 3, "minimum": 1, "maximum": 20, "description": "Spacing between metric groups in logical pixels" },
    "systemMonitorWarnThreshold": { "type": "number", "default": 0.5, "minimum": 0.1, "maximum": 0.9, "description": "Percentage threshold for warning color (0.5 = 50%)" },
    "systemMonitorCritThreshold": { "type": "number", "default": 0.8, "minimum": 0.2, "maximum": 1.0, "description": "Percentage threshold for critical color (0.8 = 80%)" },

    "mediaTitleSeparator": { "type": "string", "default": "—", "description": "Separator between artist and title in media display" },
    "panelSideMarginPx": { "type": ["integer", "null"], "default": null, "minimum": 0, "description": "Panel side margin override in pixels (null = use theme default)" },

    "panelLayout": {
      "type": "object",
      "default": {
        "left": ["clock", "workspaces", "keyboard", "network", "weather"],
        "right": ["media", "mpdFlags", "sysmon", "systray", "microphone", "volume"]
      },
      "properties": {
        "left": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered widget identifiers for the left panel"
        },
        "right": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered widget identifiers for the right panel"
        }
      },
      "description": "Widget placement in the top bar. Keys are section names, values are ordered arrays of widget identifiers."
    },

    "weatherApiBaseUrl": { "type": "string", "default": "https://api.open-meteo.com/v1", "description": "Base URL for weather API requests" },
    "weatherGeocodingBaseUrl": { "type": "string", "default": "https://geocoding-api.open-meteo.com/v1", "description": "Base URL for geocoding API requests" },
    "wallpaperAccent": { "type": "boolean", "default": true, "description": "Extract accent color from current wallpaper" }
  }
}
