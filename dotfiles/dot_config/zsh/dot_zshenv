# Deduplicate PATH entries (prevents accumulation in nested shells)
typeset -U path

# Source core environment (single source of truth for session-wide vars)
# Same file is read by systemd (environment.d) and greetd session-wrapper
set -a
source "${HOME}/.config/environment.d/10-user.conf"
set +a

# --- Shell ---
export ZDOTDIR="$HOME/.config/zsh"

# --- Tools & Paths ---
export MANWIDTH="80"

# --- MPD ---
export MPD_HOST="127.0.0.1"
export MPD_PORT="6600"
export PASSWORD_STORE_DIR="$XDG_DATA_HOME/pass"
export PASSWORD_STORE_ENABLE_EXTENSIONS_DEFAULT="true"
export ANDROID_USER_HOME="$XDG_DATA_HOME/android"
export PYTHON_HISTORY="$XDG_DATA_HOME/python/history"
export WINEPREFIX="$XDG_DATA_HOME/wineprefixes/default"
export XAUTHORITY="$XDG_RUNTIME_DIR/Xauthority"

# --- Appearance & UI ---
export EZA_COLORS="reset:da=03:uu=01:gu=0:ur=0:uw=03:ux=04;38;5;24:gr=0:gx=01;38;5;24:ue=00:tr=00:tw=00:tx=00"
export GREP_COLOR="37;45"
export GREP_COLORS="ms=0;32:mc=1;33:sl=:cx=:fn=1;32:ln=1;36:bn=36:se=1;30"
export GTK2_RC_FILES="$XDG_CONFIG_HOME/gtk-2.0/gtkrc"

# --- Search Tools ---
export FZF_DEFAULT_COMMAND="fd --type=f --hidden --exclude=.git"
export FZF_DEFAULT_OPTS_FILE="$XDG_CONFIG_HOME/fzf/fzfrc"

# --- XDG Compliance (xdg-ninja fixes) ---
export CCACHE_CONFIGPATH="$XDG_CONFIG_HOME/ccache.config"
export CCACHE_DIR="$XDG_CACHE_HOME/ccache"
export CRAWL_DIR="$XDG_DATA_HOME/crawl/"
export CUDA_CACHE_PATH="$XDG_CACHE_HOME/cuda"
export GHCUP_USE_XDG_DIRS=1
export GRIM_DEFAULT_DIR="$HOME/pic/shots"
export INPUTRC="$XDG_CONFIG_HOME/inputrc"
export _JAVA_OPTIONS="-Djava.util.prefs.userRoot=$XDG_CONFIG_HOME/java"
export LLVM_PROFILE_FILE="$XDG_CACHE_HOME/llvm/%h-%p-%m.profraw"
export NPM_CONFIG_CACHE="$XDG_CACHE_HOME/npm"
export NPM_CONFIG_INIT_MODULE="$XDG_CONFIG_HOME/npm/config/npm-init.js"
export PARALLEL_HOME="$XDG_CONFIG_HOME/parallel"
export PULSE_COOKIE="$XDG_CONFIG_HOME/pulse/cookie"
export PYLINTHOME="$XDG_CONFIG_HOME/pylint"
export TERMINFO_DIRS="$XDG_DATA_HOME/terminfo:/usr/share/terminfo"
export RANDFILE="$XDG_CACHE_HOME/openssl/rnd"
export VAGRANT_HOME="$XDG_DATA_HOME/vagrant"

# --- Performance & System ---
export __GL_VRR_ALLOWED="1"
export XZ_DEFAULTS="-T 0"
export LIBSEAT_BACKEND="logind"
