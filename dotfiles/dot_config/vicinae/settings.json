{
   "$schema": "https://vicinae.com/schemas/config.json",
   "close_on_focus_loss": true,
   "keybinding": "emacs",
   "font": {
      "rendering": "qt",
      "normal": {
         "family": "Iosevka",
         "size": 10
      }
   },
   "theme": {
      "dark": {
         "name": "flight-dark"
      }
   },
   "launcher_window": {
      "opacity": 0.85,
      "compact_mode": {
         "enabled": true
      },
      "size": {
         "width": 680,
         "height": 400
      },
      "client_side_decorations": {
         "rounding": 0,
         "border_width": 1
      },
      "layer_shell": {
         "enabled": false
      }
   },
   "favorites": [],
   "providers": {
      "clipboard": {
         "enabled": false
      }
   }
}
