# ProxyPilot — local AI proxy
# Docs: https://github.com/Finesssee/ProxyPilot
host: "127.0.0.1"
port: 8317

auth-dir: "~/.cli-proxy-api"

# ── Authentication ──────────────────────────────────────────────────

# Local API key — clients use this to auth to the proxy
api-keys:
  - "{{ gopass "api/proxypilot-local" }}"

# ── Management API ──────────────────────────────────────────────────

remote-management:
  allow-remote: false
  secret-key: "{{ gopass "api/proxypilot-management" }}"
  disable-control-panel: false

# ── Routing & failover ──────────────────────────────────────────────

routing:
  strategy: "round-robin"

request-retry: 3
max-retry-credentials: 3
max-retry-interval: 10

quota-exceeded:
  switch-project: true
  switch-preview-model: true

# ── Streaming ───────────────────────────────────────────────────────

# Keepalive for long-running requests (coding agent sessions)
streaming:
  keepalive-seconds: 15
  bootstrap-retries: 1

# Prevent idle timeouts on non-streaming requests
nonstream-keepalive-interval: 30

# ── Caching ─────────────────────────────────────────────────────────

# Response cache — dedup identical requests during dev iterations
response-cache:
  enabled: true
  max-size: 500
  ttl-seconds: 180
  exclude-models:
    - "*-thinking"

# Prompt cache — track repeated system prompts, estimate token savings
prompt-cache:
  enabled: true
  max-size: 200
  ttl-seconds: 1800

# ── Statistics & logging ────────────────────────────────────────────

usage-statistics-enabled: true

debug: false
logging-to-file: false
logs-max-total-size-mb: 100
error-logs-max-files: 10

# ── Model aliases ───────────────────────────────────────────────────
# alias = what the client sends, name = upstream model ID.
# Claude: native OAuth (--claude-login). Antigravity: Gemini models.
# Google Cloud TOS-blocked — Gemini/Antigravity tokens may not route.

oauth-model-alias:
  antigravity:
    # ── Gemini ──
    - name: "gemini-2.5-pro"
      alias: "gemini-2.5-pro"
      fork: true
    - name: "gemini-2.5-flash"
      alias: "gemini-2.5-flash"
      fork: true
    - name: "gemini-2.5-flash-lite"
      alias: "gemini-2.5-flash-lite"
      fork: true
    - name: "gemini-2.5-flash-lite"
      alias: "haiku"
      fork: true
    # ── Claude (via Antigravity, direct OAuth broken) ──
    - name: "claude-sonnet-4-6"
      alias: "claude-sonnet-4-6"
      fork: true
    - name: "claude-opus-4-6"
      alias: "claude-opus-4-6"
      fork: true
    - name: "claude-haiku-4-5-20251001"
      alias: "claude-haiku-4-5-20251001"
      fork: true

# ── Free fallback providers (emergency-only) ──────────────────────────
# Activated via dedicated fallback-* aliases when paid providers are down.
# Providers resolved from states/data/free_providers.yaml at Salt apply time.
openai-compatibility:
  - name: "groq"
    base-url: "https://api.groq.com/openai/v1"
    api-key-entries:
      - api-key: "{{ gopass "api/groq" }}"
    models:
      - name: "llama-3.3-70b-versatile"
        alias: "fallback-large"
      - name: "qwen/qwen3-32b"
        alias: "fallback-medium"
  - name: "cerebras"
    base-url: "https://api.cerebras.ai/v1"
    api-key-entries:
      - api-key: "{{ gopass "api/cerebras" }}"
    models:
      - name: "qwen-3-235b-a22b-instruct"
        alias: "fallback-large"
      - name: "llama3.1-8b"
        alias: "fallback-small"
  - name: "openrouter"
    base-url: "https://openrouter.ai/api/v1"
    api-key-entries:
      - api-key: "{{ gopass "api/openrouter" }}"
    models:
      - name: "qwen/qwen3-coder-480b-a35b:free"
        alias: "fallback-code"
      - name: "openrouter/auto"
        alias: "fallback-large"
  - name: "deepseek"
    base-url: "https://api.deepseek.com/v1"
    api-key-entries:
      - api-key: "{{ gopass "api/deepseek" }}"
    models:
      - name: "deepseek-chat"
        alias: "fallback-code"
      - name: "deepseek-reasoner"
        alias: "fallback-large"
  - name: "ollama"
    base-url: "http://localhost:11434/v1"
    api-key-entries:
      - api-key: "ollama"
    models:
      - name: "qwen3.5:27b"
        alias: "fallback-large"
      - name: "qwen2.5-coder:7b"
        alias: "fallback-code"
      - name: "qwen3:14b"
        alias: "fallback-medium"


# ── Payload rules ───────────────────────────────────────────────────
# Default thinking budget for Gemini models (when not set by client)

payload:
  default:
    # OpenCode sends reasoning.effort=minimal for title generation.
    # Proxy backend supports only low|medium|high, so normalize it.
    - models:
        - name: "gpt-5*"
          protocol: "openai"
      params:
        "reasoning.effort": "low"
    - models:
        - name: "gemini-*"
          protocol: "gemini"
      params:
        "generationConfig.thinkingConfig.thinkingBudget": 16384
