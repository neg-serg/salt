{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "http://127.0.0.1:8317/v1",
        "apiKey": "{env:OPENAI_API_KEY}",
        "timeout": 600000
      }
    }
  },
  "model": "openai/gpt-5-codex",
  "small_model": "openai/gpt-5.2",
  "enabled_providers": ["openai"]
}
