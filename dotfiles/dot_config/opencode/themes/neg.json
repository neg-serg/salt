    "primary":        "#005faf",
    "primaryDim":     "#005f87",
    "accent":         "#477AB3",
    "teal":           "#287373",
    "tealBright":     "#53A6A6",
    "magenta":        "#8A2F58",
    "magentaBright":  "#CF4F88",
    "purple":         "#5E468C",
    "purpleBright":   "#7E62B3",
    "cyan":           "#31658C",
    "cyanBright":     "#6096BF",
    "yellow":         "#914E89",
    "yellowBright":   "#BF85CC",
    "green":          "#287373",
    "greenBright":    "#53A6A6",
    "borderDim":      "#10233a",
    "borderNorm":     "#1c334e",
    "borderActive":   "#2b4462",
    "gray1":          "#071526",
    "gray2":          "#162b44",
    "gray3":          "#233b58",
    "gray4":          "#496280",
    "gray5":          "#546c8a",
    "gray6":          "#607794",
    "textLight":      "#8d9eb2",
