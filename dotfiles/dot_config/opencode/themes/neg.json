  "theme": {
    "primary":        "primary",
    "secondary":      "cyan",
    "accent":         "accent",
    "error":          "magentaBright",
    "warning":        "yellowBright",
    "success":        "tealBright",
    "info":           "cyanBright",

    "text":           "fgBright",
    "textMuted":      "fgMuted",
    "background":     "bg",
    "backgroundPanel":   "panelBg",
    "backgroundElement": "elementBg",

    "border":         "borderNorm",
    "borderActive":   "borderActive",
    "borderSubtle":   "borderDim",

    "diffAdded":         "tealBright",
    "diffRemoved":       "magentaBright",
    "diffContext":        "fgMuted",
    "diffHunkHeader":    "gray5",
    "diffHighlightAdded":    "greenBright",
    "diffHighlightRemoved":  "magentaBright",
    "diffAddedBg":       "gray1",
    "diffRemovedBg": {
      "dark": "#180818",
      "light": "#180818"
    },
    "diffContextBg":     "panelBg",
    "diffLineNumber":    "fgSubtle",
    "diffAddedLineNumberBg":   "gray1",
    "diffRemovedLineNumberBg": {
      "dark": "#180818",
      "light": "#180818"
    },

    "markdownText":            "fgBright",
    "markdownHeading":         "primary",
    "markdownLink":            "accent",
    "markdownLinkText":        "cyanBright",
    "markdownCode":            "tealBright",
    "markdownBlockQuote":      "fgMuted",
    "markdownEmph":            "yellowBright",
    "markdownStrong":          "selFg",
    "markdownHorizontalRule":  "borderNorm",
    "markdownListItem":        "primaryDim",
    "markdownListEnumeration": "accent",
    "markdownImage":           "purpleBright",
    "markdownImageText":       "cyanBright",
    "markdownCodeBlock":       "fg",

    "syntaxComment":     "fgMuted",
    "syntaxKeyword":     "purpleBright",
    "syntaxFunction":    "cyanBright",
    "syntaxVariable":    "tealBright",
    "syntaxString":      "teal",
    "syntaxNumber":      "magenta",
    "syntaxType":        "accent",
    "syntaxOperator":    "primary",
    "syntaxPunctuation": "fg"
