    "primary":        "#0055A0",
    "primaryDim":     "#004D7A",
    "accent":         "#3A6A9E",
    "teal":           "#1E6060",
    "tealBright":     "#3D8A8A",
    "magenta":        "#A02E60",
    "magentaBright":  "#B83E74",
    "purple":         "#553D85",
    "purpleBright":   "#6B52A3",
    "cyan":           "#255878",
    "cyanBright":     "#4A80AA",
    "yellow":         "#7D3E78",
    "yellowBright":   "#A06CB0",
    "green":          "#1E6060",
    "greenBright":    "#3D8A8A",
    "borderDim":      "#BCC8D6",
    "borderNorm":     "#A8B8CA",
    "borderActive":   "#95A8BE",
    "gray1":          "#E0E5ED",
    "gray2":          "#CCD4E0",
    "gray3":          "#B8C4D4",
    "gray4":          "#8A9AB0",
    "gray5":          "#7A8FA6",
    "gray6":          "#6B809A",
    "textLight":      "#4A5E74",
    "textBright":     "#3A4F66"
