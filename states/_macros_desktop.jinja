{# Desktop session macros: browser_extensions, hyprpm_update, hyprpm_add, hyprpm_enable, dconf_settings #}

{% from '_macros_common.jinja' import user as _user, home as _home, host, retry_attempts as _retry_attempts, retry_interval as _retry_interval %}
{% from '_macros_service.jinja' import ensure_dir as _ensure_dir %}
{% from '_macros_install.jinja' import firefox_extension as _firefox_extension %}

{# Install browser extensions, remove unwanted ones, and reset extensions.json.
   prefix:       unique prefix for state IDs (e.g. 'floorp', 'zen')
   profile:      absolute path to browser profile directory
   extensions:   list of {id, slug, ...} dicts (passed to firefox_extension)
   user_js_id:   state ID of the user.js file.managed (for onchanges trigger)
   unwanted:     optional list of extension IDs to remove (e.g. ['{ext-guid}'])
   Usage: {{ browser_extensions('floorp', floorp_profile, floorp.extensions, 'floorp_user_js', unwanted=floorp.unwanted) }}
#}
{%- macro browser_extensions(prefix, profile, extensions, user_js_id, unwanted=None, user=_user) -%}
{{ _ensure_dir(prefix ~ '_extensions_dir', profile ~ '/extensions') }}

{%- for ext in extensions %}
{{ _firefox_extension(ext, profile, require=prefix ~ '_extensions_dir', user=user, prefix=prefix ~ '_ext') }}
{%- endfor %}

{%- if unwanted %}
{% for ext_id in unwanted %}
{%- set safe_id = ext_id | replace('{', '') | replace('}', '') | replace('-', '_') | replace('@', '_') | replace('.', '_') %}
{{ prefix }}_remove_{{ safe_id }}:
  file.absent:
    - name: {{ profile }}/extensions/{{ ext_id }}.xpi
{% endfor %}
{%- endif %}

{{ prefix }}_reset_extensions_json:
  file.absent:
    - name: {{ profile }}/extensions.json
    - onchanges_any:
      - file: {{ user_js_id }}
{%- for ext in extensions %}
      - cmd: {{ prefix }}_ext_{{ ext.slug | replace('-', '_') }}
{%- endfor %}
{%- endmacro -%}

{# --- Internal: shared hyprpm environment block ---
   All hyprpm operations need HYPRLAND_INSTANCE_SIGNATURE from the running
   compositor. The onlyif guard skips gracefully when Hyprland is not running.
#}
{%- set _hypr_sig_cmd = 'ls /run/user/' ~ host.uid ~ '/hypr/ 2>/dev/null | head -1' -%}
{%- set _hypr_onlyif = 'ls /run/user/' ~ host.uid ~ '/hypr/ 2>/dev/null | grep -q .' -%}

{# Shared env block for hyprpm commands (HOME + XDG_RUNTIME_DIR) #}
{%- set _hypr_env = [
  'HOME: ' ~ _home,
  'XDG_RUNTIME_DIR: ' ~ host.runtime_dir,
] -%}

{# Update hyprpm headers (rebuilds plugin headers for current Hyprland version).
   check_plugins: optional list of plugin names to verify (all must exist in hyprpm list
   for the state to be skipped).
   Usage: {{ hyprpm_update('hyprpm_headers_update', check_plugins=['xtra-dispatchers', 'HyprGlass'], require=['cmd: install_hyprland_desktop', 'file: hyprpm_cache_dir']) }}
#}
{%- macro hyprpm_update(name, check_plugins=None, require=None, timeout=300) -%}
{{ name }}:
  cmd.run:
    - name: >-
        export HYPRLAND_INSTANCE_SIGNATURE=$( {{ _hypr_sig_cmd }} ) &&
        hyprpm update
    - runas: {{ _user }}
    - onlyif: {{ _hypr_onlyif }}
{%- if check_plugins %}
    - unless: >-
        export HYPRLAND_INSTANCE_SIGNATURE=$( {{ _hypr_sig_cmd }} ) &&
{%- for plugin in check_plugins %}
        hyprpm list 2>&1 | grep -q '{{ plugin }}'{{ ' &&' if not loop.last else '' }}
{%- endfor %}
{%- endif %}
    - env:
{%- for entry in _hypr_env %}
      - {{ entry }}
{%- endfor %}
{%- if require %}
    - require:
{%- for req in require %}
      - {{ req }}
{%- endfor %}
{%- endif %}
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
    - timeout: {{ timeout }}
{%- endmacro -%}

{# Add a hyprpm plugin repository.
   repo_url: git URL of the plugin repo.
   check_plugin: string to verify in hyprpm list (e.g. 'Repository hyprland-plugins').
   Usage: {{ hyprpm_add('hyprpm_add_hyprland_plugins', 'https://github.com/hyprwm/hyprland-plugins', 'Repository hyprland-plugins', require=['cmd: hyprpm_headers_update']) }}
#}
{%- macro hyprpm_add(name, repo_url, check_plugin, require=None, timeout=300) -%}
{{ name }}:
  cmd.run:
    - name: >-
        export HYPRLAND_INSTANCE_SIGNATURE=$( {{ _hypr_sig_cmd }} ) &&
        yes | hyprpm add {{ repo_url }}
    - runas: {{ _user }}
    - onlyif: {{ _hypr_onlyif }}
    - unless: >-
        export HYPRLAND_INSTANCE_SIGNATURE=$( {{ _hypr_sig_cmd }} ) &&
        hyprpm list 2>&1 | grep -q '{{ check_plugin }}'
    - env:
{%- for entry in _hypr_env %}
      - {{ entry }}
{%- endfor %}
{%- if require %}
    - require:
{%- for req in require %}
      - {{ req }}
{%- endfor %}
{%- endif %}
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
    - timeout: {{ timeout }}
{%- endmacro -%}

{# Enable a hyprpm plugin.
   plugin: plugin name to enable.
   Usage: {{ hyprpm_enable('hyprpm_enable_xtra_dispatchers', 'xtra-dispatchers', require=['cmd: hyprpm_add_hyprland_plugins']) }}
#}
{%- macro hyprpm_enable(name, plugin, require=None) -%}
{{ name }}:
  cmd.run:
    - name: >-
        export HYPRLAND_INSTANCE_SIGNATURE=$( {{ _hypr_sig_cmd }} ) &&
        hyprpm enable {{ plugin }}
    - runas: {{ _user }}
    - onlyif: {{ _hypr_onlyif }}
    - unless: >-
        export HYPRLAND_INSTANCE_SIGNATURE=$( {{ _hypr_sig_cmd }} ) &&
        hyprpm list 2>&1 | grep -A1 '{{ plugin }}' | grep -q 'enabled:.*true'
    - env:
{%- for entry in _hypr_env %}
      - {{ entry }}
{%- endfor %}
{%- if require %}
    - require:
{%- for req in require %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{# Apply dconf settings from a key-value dictionary.
   Handles escaping of special chars (backslash, quotes, backticks, $) in both
   the write commands and the mirrored unless guard.
   settings: dict of dconf path → value (e.g. {'/org/gnome/desktop/interface/gtk-theme': 'adw-gtk3-dark'}).
   Usage: {{ dconf_settings('dconf_themes', desktop.dconf_settings) }}
#}
{%- macro dconf_settings(name, settings, user=_user, require=None) -%}
{{ name }}:
  cmd.run:
    - name: |
        set -eo pipefail
{%- for key, val in settings.items() %}
{%- set safe = val | replace('\\', '\\\\') | replace('"', '\\"') | replace('`', '\\`') | replace('$', '\\$') %}
        dconf write {{ key }} "'{{ safe }}'"
{%- endfor %}
    - shell: /bin/bash
    - runas: {{ user }}
    - env:
      - DBUS_SESSION_BUS_ADDRESS: "unix:path={{ host.runtime_dir }}/bus"
    - unless: |
        export DBUS_SESSION_BUS_ADDRESS=unix:path={{ host.runtime_dir }}/bus
{%- for key, val in settings.items() %}
{%- set safe = val | replace('\\', '\\\\') | replace('"', '\\"') | replace('`', '\\`') | replace('$', '\\$') %}
        test "$(dconf read {{ key }})" = "'{{ safe }}'"{{ ' &&' if not loop.last else '' }}
{%- endfor %}
{%- if require %}
    - require:
{%- for req in require %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}
