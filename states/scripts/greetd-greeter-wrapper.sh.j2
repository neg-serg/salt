#!/bin/sh
# Greeter wrapper: runs quickshell greeter inside cage kiosk compositor.
# cage (wlroots-based) handles SIGTERM cleanly — no DRM workarounds needed,
# unlike Hyprland's aquamarine which has a 5-second modeset timeout.
#
# Crash guard: if the greeter crashes 3 times within 30 seconds,
# falls back to agreety (terminal greeter). Normal login resets the counter
# because the session lasts longer than 30s.

CRASH_FILE=/tmp/greetd-crash-count

if [ -f "$CRASH_FILE" ] && [ $(($(date +%s) - $(stat -c %Y "$CRASH_FILE"))) -lt 30 ]; then
    count=$(cat "$CRASH_FILE")
else
    count=0
fi
count=$((count + 1))
echo "$count" > "$CRASH_FILE"

if [ "$count" -ge 3 ]; then
    echo 0 > "$CRASH_FILE"
    exec agreety --cmd /etc/greetd/session-wrapper
fi

export GREETER_MODE=cage
export QT_QPA_PLATFORM=wayland
{% if greetd_scale > 1 %}
export QT_SCALE_FACTOR={{ greetd_scale }}
{% endif %}
export QT_WAYLAND_DISABLE_WINDOWDECORATION=1
export XCURSOR_THEME={{ cursor_theme }}
export XCURSOR_SIZE={{ cursor_size }}
export XKB_DEFAULT_LAYOUT=us,ru
export XKB_DEFAULT_OPTIONS=grp:alt_shift_toggle

ulimit -c 0
{% if primary_output and display %}
exec cage -s -- sh -c 'wlr-randr --output {{ primary_output }} --mode {{ display }}Hz; exec qs -p {{ home }}/.config/quickshell/greeter/greeter.qml'
{% else %}
exec cage -s -- qs -p {{ home }}/.config/quickshell/greeter/greeter.qml
{% endif %}
