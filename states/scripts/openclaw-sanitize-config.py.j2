#!/usr/bin/env python3
"""Sanitize OpenClaw config before gateway startup.

Two-layer filtering:
  Layer 1: Remove models with contextWindow <= 0 or maxTokens <= 0
           (catches auto-populated STT models like Groq Whisper).
  Layer 2: Remove models not on the per-provider allowlist
           (catches any unexpected auto-populated model).

Also validates JSON syntax before processing — exits 1 on invalid JSON
to prevent crash loops (systemd won't start the main process).

Allowlist is embedded at Salt apply time from states/data/openclaw_models.yaml.
"""
{% raw %}
import json
import subprocess
import sys
from pathlib import Path

# Per-provider model allowlist (rendered by Salt from openclaw_models.yaml).
# Providers not listed: only Layer 1 (zero-value) filtering applies.
{% endraw -%}
ALLOWED_MODELS = {
{%- for provider, models in allowed_models.items() %}
    {{ provider | tojson }}: {{ models | tojson }},
{%- endfor %}
}
{% raw %}
CONFIG = Path.home() / ".openclaw" / "openclaw.json"

if not CONFIG.exists():
    sys.exit(0)

try:
    data = json.loads(CONFIG.read_text())
except json.JSONDecodeError as e:
    print(f"openclaw-sanitize: invalid JSON in config: {e}", file=sys.stderr)
    sys.exit(1)

providers = data.get("models", {}).get("providers", {})
changed = False

# ── Layer 1: strip models with invalid metadata ─────────────────────
for name, prov in providers.items():
    models = prov.get("models", [])
    valid = [m for m in models if m.get("contextWindow", 0) > 0 and m.get("maxTokens", 0) > 0]
    if len(valid) != len(models):
        removed_ids = [m.get("id", "?") for m in models if m not in valid]
        print(
            f"openclaw-sanitize: [{name}] removed {len(removed_ids)} model(s) "
            f"with invalid metadata (contextWindow/maxTokens <= 0): {removed_ids}",
            file=sys.stderr,
        )
        prov["models"] = valid
        changed = True

# ── Layer 2: strip models not on the allowlist ──────────────────────
for name, prov in providers.items():
    if name not in ALLOWED_MODELS:
        continue  # provider not in allowlist — Layer 1 only
    allowed = ALLOWED_MODELS[name]
    models = prov.get("models", [])
    valid = [m for m in models if m.get("id") in allowed]
    if len(valid) != len(models):
        removed_ids = [m.get("id", "?") for m in models if m.get("id") not in allowed]
        print(
            f"openclaw-sanitize: [{name}] removed {len(removed_ids)} model(s) "
            f"not on allowlist: {removed_ids}",
            file=sys.stderr,
        )
        prov["models"] = valid
        changed = True

if changed:
    CONFIG.write_text(json.dumps(data, indent=2) + "\n")

# Schema validation (informational — don't block startup on schema issues)
try:
    result = subprocess.run(
        ["openclaw", "config", "validate"], capture_output=True, text=True, timeout=10
    )
    if result.returncode != 0:
        print(f"openclaw-sanitize: config validate warning: {result.stderr.strip()}")
except (FileNotFoundError, subprocess.TimeoutExpired):
    pass  # openclaw binary not found or timeout — skip
{% endraw %}
