{#- Thin proxy: re-exports constants from _macros_common.jinja for .sls states.
    Jinja2 {% from %} imports do NOT re-export — only {% set %} creates module exports.
    Usage: {% from '_imports.jinja' import host, user, home %}
    With pkg_list: {% from '_imports.jinja' import host, user, home, pkg_list %}
-#}
{%- import '_macros_common.jinja' as _mc -%}
{%- set host = _mc.host -%}
{%- set user = _mc.user -%}
{%- set home = _mc.home -%}
{%- set pkg_list = _mc.pkg_list -%}
{%- set retry_attempts = _mc.retry_attempts -%}
{%- set retry_interval = _mc.retry_interval -%}
{%- set healthcheck_timeout = _mc.healthcheck_timeout -%}
{%- set sudo_timeout_minutes = _mc.sudo_timeout_minutes -%}
{%- set ollama_pull_timeout = _mc.ollama_pull_timeout -%}
{%- set service_ports = _mc.service_ports -%}
{%- set ver_dir = _mc.ver_dir -%}
{%- set sys_ver_dir = _mc.sys_ver_dir -%}
