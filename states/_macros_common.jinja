{#- Single source of truth for all shared constants.
    Imported by macro files (as _user, _home, …) and re-exported by _imports.jinja for .sls states.
    Usage (macros):  {% from '_macros_common.jinja' import user as _user, home as _home, ... %}
    Usage (states):  {% from '_imports.jinja' import host, user, home, ... %}
-#}
{%- import 'host_config.jinja' as _hc with context -%}
{%- set host = _hc.host -%}
{%- set user = host.user -%}
{%- set home = host.home -%}
{%- set pkg_list = host.pkg_list -%}
{%- set retry_attempts = 3 -%}
{%- set retry_interval = 10 -%}
{%- set ver_dir = home ~ '/.cache/salt-versions' -%}
{%- set sys_ver_dir = '/var/cache/salt/versions' -%}
{%- set download_cache = '/var/cache/salt/downloads' -%}
{%- set healthcheck_timeout = 30 -%}
{%- set sudo_timeout_minutes = 30 -%}
{%- set ollama_pull_timeout = 660 -%}

{#- Shell one-liner: write version marker file (used inside cmd.run name: blocks) -#}
{%- macro ver_stamp(vd, name, version) -%}
mkdir -p {{ vd }} && echo '{{ version }}' > {{ vd }}/{{ name }}
{%- endmacro -%}
{#- Resolve a secret from gopass, with optional shell fallback command.
    Returns the secret value, or the fallback result (empty string if no fallback).
    Uses host.user by default; override with runas='other'.
    Usage: {% set key = gopass_secret('api/my-key') %}
           {% set key = gopass_secret('api/my-key', "awk '...' /path/to/config") %}
-#}
{%- macro gopass_secret(key, fallback_cmd='true', runas=None) -%}
{%- set _u = runas if runas is not none else host.user -%}
{%- set _r = salt['cmd.run_all']('gopass show -o ' ~ key ~ ' 2>/dev/null', runas=_u, python_shell=True, ignore_retcode=True) -%}
{%- if _r.get('retcode', 1) == 0 -%}
{{ _r['stdout'].strip() }}
{%- else -%}
{{ salt['cmd.run_stdout'](fallback_cmd, runas=_u).strip() }}
{%- endif -%}
{%- endmacro -%}

{%- set service_ports = {
    'loki':         {'port': 3100, 'healthcheck': '/ready'},
    'promtail':     {'port': 9080, 'healthcheck': '/ready'},
    'grafana':      {'port': 3030, 'healthcheck': '/api/health'},
    'adguardhome':  {'port': 3000, 'healthcheck': '/'},
    'ollama':       {'port': 11434, 'healthcheck': '/api/tags'},
    'llama_embed':  {'port': 11435, 'healthcheck': '/health'},
} -%}
