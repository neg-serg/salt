{#- Single source of truth for all shared constants.
    Imported by macro files (as _user, _home, …) and re-exported by _imports.jinja for .sls states.
    Usage (macros):  {% from '_macros_common.jinja' import user as _user, home as _home, ... %}
    Usage (states):  {% from '_imports.jinja' import host, user, home, ... %}
-#}
{%- import 'host_config.jinja' as _hc with context -%}
{%- set host = _hc.host -%}
{%- set user = host.user -%}
{%- set home = host.home -%}
{%- set pkg_list = host.pkg_list -%}
{%- set retry_attempts = 3 -%}
{%- set retry_interval = 10 -%}
{%- set ver_dir = home ~ '/.cache/salt-versions' -%}
{%- set sys_ver_dir = '/var/cache/salt/versions' -%}
{%- set download_cache = '/var/cache/salt/downloads' -%}
{%- set healthcheck_timeout = 30 -%}
{%- set sudo_timeout_minutes = -1 -%}
{%- set ollama_pull_timeout = 14400 -%}

{#- Shell one-liner: create version-encoded marker (used inside cmd.run name: blocks).
    target: absolute path to installed artifact — creates a symlink so creates: detects deletion.
    When omitted, creates a plain touch file (for cases without a single artifact, e.g. fonts).
    Old-format markers (plain name) and stale versioned markers (name@*) are cleaned up. -#}
{%- macro ver_stamp(vd, name, version, target=None) -%}
mkdir -p {{ vd }} && rm -f '{{ vd }}/{{ name }}' {{ vd }}/{{ name }}@* && {% if target %}ln -sf '{{ target }}' '{{ vd }}/{{ name }}@{{ version }}'{% else %}touch '{{ vd }}/{{ name }}@{{ version }}'{% endif %}
{%- endmacro -%}
{#- Resolve a secret from gopass, with optional shell fallback command.
    Returns the secret value, or the fallback result (empty string if no fallback).
    Uses host.user by default; override with runas='other'.
    Optimisation: the first call probes gopass availability; if gopass is
    unreachable (daemon context — no GPG agent), subsequent calls skip the
    gopass attempt entirely and use the fallback command directly.
    Usage: {% set key = gopass_secret('api/my-key') %}
           {% set key = gopass_secret('api/my-key', "awk '...' /path/to/config") %}
-#}
{%- set _gopass_ns = namespace(checked=False, available=False) -%}
{%- macro gopass_secret(key, fallback_cmd='true', runas=None) -%}
{%- set _u = runas if runas is not none else host.user -%}
{%- set _try_gopass = (not _gopass_ns.checked) or _gopass_ns.available -%}
{%- if _try_gopass -%}
{%- set _r = salt['cmd.run_all']('gopass show -o ' ~ key ~ ' 2>/dev/null', runas=_u, python_shell=True, ignore_retcode=True) -%}
{%- if not _gopass_ns.checked -%}
{%- set _gopass_ns.checked = True -%}
{%- set _gopass_ns.available = (_r.get('retcode', 1) == 0) -%}
{%- endif -%}
{%- if _r.get('retcode', 1) == 0 -%}
{{- _r['stdout'].strip() -}}
{%- else -%}
{{- salt['cmd.run_stdout'](fallback_cmd, runas=_u, python_shell=True).strip() -}}
{%- endif -%}
{%- else -%}
{{- salt['cmd.run_stdout'](fallback_cmd, runas=_u, python_shell=True).strip() -}}
{%- endif -%}
{%- endmacro -%}

{#- Convenience wrappers for frequently-used secrets.
    Centralise the fallback commands so each .sls file doesn't have to
    copy-paste the same awk/cat one-liners.
-#}
{%- macro proxypilot_key() -%}
{{ gopass_secret('api/proxypilot-local', "awk '/^api-keys:/{getline; sub(/^[[:space:]]*-[[:space:]]*\"?/, \"\"); sub(/\"?[[:space:]]*$/, \"\"); print; exit}' " ~ home ~ "/.config/proxypilot/config.yaml 2>/dev/null || true") }}
{%- endmacro -%}

{%- macro tg_secret(gopass_key, cred_file, cred_base=None) -%}
{%- set _base = cred_base if cred_base else (home ~ '/.openclaw/credentials') -%}
{{ gopass_secret(gopass_key, "cat " ~ _base ~ "/" ~ cred_file ~ " 2>/dev/null || true") }}
{%- endmacro -%}
