    'caldera': {
        'display':        '1920x1080@60',
        'primary_output': 'HDMI-A-1',
        'hostname':       'caldera',
        'features': {
            'monitoring': { 'loki': True, 'promtail': True, 'grafana': True },
            'dns':        { 'unbound': True, 'adguardhome': True },
