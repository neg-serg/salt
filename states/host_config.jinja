    'cursor_theme':   'Alkano-aio',
    'cursor_size':    23,
    'cpu_vendor':     'amd',
    'kvm_module':     'kvm_amd',
    'display':        '',
    'primary_output': '',
    'greetd_vt':      1,
    'greetd_scale':   1,
    'timezone':       'Europe/Moscow',
    'locale':         'en_US.UTF-8',
    'floorp_profile': '',
    'hostname':       grains['host'],
    'extra_kargs':    [],
    'extra_modules':  [],
    'features': {
        'monitoring': {
            'sysstat':  True,
            'vnstat':   True,
            'netdata':  True,
