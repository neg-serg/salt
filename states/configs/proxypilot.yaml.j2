# ProxyPilot — local AI proxy
# Docs: https://github.com/Finesssee/ProxyPilot
{%- set _cfg_path = home ~ '/.config/proxypilot/config.yaml' -%}
{%- set _gopass_api_key = salt['cmd.run_stdout']('gopass show -o api/proxypilot-local 2>/dev/null || true', runas=user).strip() -%}
{%- set _file_api_key = salt['cmd.run_stdout']("awk '/^api-keys:/{getline; sub(/^[[:space:]]*-[[:space:]]*\"?/, \"\"); sub(/\"?[[:space:]]*$/, \"\"); print; exit}' " ~ _cfg_path ~ " 2>/dev/null || true", runas=user).strip() -%}
{%- set _api_key = _gopass_api_key or _file_api_key -%}
{%- set _gopass_mgmt_key = salt['cmd.run_stdout']('gopass show -o api/proxypilot-management 2>/dev/null || true', runas=user).strip() -%}
{%- set _file_mgmt_key = salt['cmd.run_stdout']("awk '/^[[:space:]]*secret-key:[[:space:]]*/{sub(/^[[:space:]]*secret-key:[[:space:]]*\"?/, \"\"); sub(/\"?[[:space:]]*$/, \"\"); print; exit}' " ~ _cfg_path ~ " 2>/dev/null || true", runas=user).strip() -%}
{%- set _mgmt_key = _gopass_mgmt_key or _file_mgmt_key %}
host: "127.0.0.1"
port: 8317
auth-dir: "~/.cli-proxy-api"
# ── Authentication ──────────────────────────────────────────────────
# Local API key — clients use this to auth to the proxy
api-keys:
  - "{{ _api_key }}"
# ── Management API ──────────────────────────────────────────────────
remote-management:
  allow-remote: false
  secret-key: "{{ _mgmt_key }}"
  disable-control-panel: false
# ── Routing & failover ──────────────────────────────────────────────
routing:
  strategy: "round-robin"
request-retry: 3
max-retry-credentials: 3
max-retry-interval: 30
quota-exceeded:
  switch-project: true
  switch-preview-model: true
# ── Streaming ───────────────────────────────────────────────────────
# Keepalive for long-running requests (coding agent sessions)
streaming:
  keepalive-seconds: 15
  bootstrap-retries: 1
# Prevent idle timeouts on non-streaming requests
nonstream-keepalive-interval: 30
# ── Caching ─────────────────────────────────────────────────────────
# Response cache — dedup identical requests during dev iterations
response-cache:
  enabled: true
  max-size: 500
  ttl-seconds: 180
  exclude-models:
    - "*-thinking"
# Prompt cache — track repeated system prompts, estimate token savings
prompt-cache:
  enabled: true
  max-size: 200
  ttl-seconds: 1800
# ── Statistics & logging ────────────────────────────────────────────
usage-statistics-enabled: true
debug: false
logging-to-file: false
logs-max-total-size-mb: 100
error-logs-max-files: 10
# ── Model aliases ───────────────────────────────────────────────────
# Claude Code sends versioned model names (claude-sonnet-4-6-20250514).
# Map them to the actual models available through Antigravity OAuth.
oauth-model-alias:
  antigravity:
    # Claude Code model names → Antigravity models
    - name: "claude-sonnet-4-6"
      alias: "claude-sonnet-4-6-20250514"
      fork: true
    - name: "claude-opus-4-6-thinking"
      alias: "claude-opus-4-6-20251022"
      fork: true
    - name: "claude-opus-4-6-thinking"
      alias: "opus"
      fork: true
    - name: "claude-sonnet-4-6"
      alias: "sonnet"
      fork: true
    - name: "gemini-2.5-flash-lite"
      alias: "haiku"
      fork: true
# ── Payload rules ───────────────────────────────────────────────────
# Default thinking budget for Gemini models (when not set by client)
payload:
  default:
    # OpenCode sends reasoning.effort=minimal for title generation.
    # Proxy backend supports only low|medium|high, so normalize it.
    - models:
        - name: "gpt-5*"
          protocol: "openai"
      params:
        "reasoning.effort": "low"
    - models:
        - name: "gemini-*"
          protocol: "gemini"
      params:
        "generationConfig.thinkingConfig.thinkingBudget": 16384
