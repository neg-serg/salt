      "title": "Requests by Status Code",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (status_class) (count_over_time({syslog_identifier=\"proxypilot\"} | pattern `<_> <_> <_> <_> <status> | <_>` | status =~ `2\\d{2}` | status_class = `2xx` [$__interval]))",
          "legendFormat": "2xx",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({syslog_identifier=\"proxypilot\"} |~ `\\] 4\\d{2} \\|` [$__interval]))",
          "legendFormat": "4xx",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({syslog_identifier=\"proxypilot\"} |~ `\\] 5\\d{2} \\|` [$__interval]))",
          "legendFormat": "5xx",
          "refId": "C"
        }
      ]
    },
