      "title": "Total Requests",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({syslog_identifier=\"proxypilot\"} |~ `\\| (POST|GET|PUT|DELETE|PATCH)\\s` [$__range]))",
