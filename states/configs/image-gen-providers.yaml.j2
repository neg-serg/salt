# Image generation providers — rendered by Salt from states/data/image_providers.yaml
# Secrets resolved from gopass at apply time. DO NOT edit manually.
# Used by: ~/.local/bin/gen-image
{%- if providers %}
providers:
{%- for p in providers %}
  - name: "{{ p.name }}"
    base_url: "{{ p.base_url }}"
    api_type: "{{ p.api_type }}"
    api_key: "{{ p.api_key }}"
{%- if p.account_id is defined and p.account_id %}
    account_id: "{{ p.account_id }}"
{%- endif %}
    priority: {{ p.priority }}
    models:
{%- for m in p.models %}
      - name: "{{ m.name }}"
        alias: "{{ m.alias }}"
{%- endfor %}
{%- endfor %}
{%- else %}
# WARNING: No image providers resolved. Check gopass keys.
providers: []
{%- endif %}
