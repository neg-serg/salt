{
  "prompt": {
    "1": {
      "class_type": "UNETLoader",
      "inputs": {
        "unet_name": "__MODEL_FILE__",
        "weight_dtype": "fp8_e4m3fn"
      }
    },
    "1v": {
      "class_type": "VAELoader",
      "inputs": {
        "vae_name": "LTX23_video_vae_bf16.safetensors"
      }
    },
    "2": {
      "class_type": "DualCLIPLoader",
      "inputs": {
        "clip_name1": "gemma_3_12B_it_fp4_mixed.safetensors",
        "clip_name2": "ltx-2.3_text_projection_bf16.safetensors",
        "type": "ltxv"
      }
    },
    "3": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "__PROMPT__",
        "clip": ["2", 0]
      }
    },
    "4": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "worst quality, blurry, distorted, low resolution",
        "clip": ["2", 0]
      }
    },
    "5": {
      "class_type": "LTXVConditioning",
      "inputs": {
        "positive": ["3", 0],
        "negative": ["4", 0],
        "frame_rate": 24.0
      }
    },
    "10": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "__IMAGE__",
        "upload": "image"
      }
    },
    "11": {
      "class_type": "LTXVImgToVideo",
      "inputs": {
        "positive": ["5", 0],
        "negative": ["5", 1],
        "vae": ["1v", 0],
        "image": ["10", 0],
        "width": __WIDTH__,
        "height": __HEIGHT__,
        "length": __FRAMES__,
        "batch_size": 1,
        "strength": 0.9
      }
    },
    "20": {
      "class_type": "LTXVApplySTG",
      "inputs": {
        "model": ["1", 0],
        "block_indices": "14, 19"
      }
    },
    "21": {
      "class_type": "STGGuider",
      "inputs": {
        "model": ["20", 0],
        "positive": ["11", 0],
        "negative": ["11", 1],
        "cfg": 4.0,
        "stg": 1.0,
        "rescale": 0.7
      }
    },
    "22": {
      "class_type": "LTXVScheduler",
      "inputs": {
        "steps": __STEPS__,
        "max_shift": 2.05,
        "base_shift": 0.95,
        "stretch": true,
        "terminal": 0.1
      }
    },
    "23": {
      "class_type": "KSamplerSelect",
      "inputs": {
        "sampler_name": "euler"
      }
    },
    "24": {
      "class_type": "RandomNoise",
      "inputs": {
        "noise_seed": 0
      }
    },
    "30": {
      "class_type": "LTXVBaseSampler",
      "inputs": {
        "model": ["20", 0],
        "vae": ["1v", 0],
        "width": __WIDTH__,
        "height": __HEIGHT__,
        "num_frames": __FRAMES__,
        "guider": ["21", 0],
        "sampler": ["23", 0],
        "sigmas": ["22", 0],
        "noise": ["24", 0]
      }
    },
    "40": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["30", 0],
        "vae": ["1v", 0]
      }
    },
    "50": {
      "class_type": "SaveImage",
      "inputs": {
        "images": ["40", 0],
        "filename_prefix": "ltx23-video"
      }
    }
  }
}
