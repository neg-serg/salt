{
  "prompt": {
    "1": {
      "class_type": "CogVideoModelLoader",
      "inputs": {
        "model_name": "checkpoints/cogvideox-5b",
        "precision": "bf16",
        "enable_model_cpu_offload": true,
        "enable_sequential_cpu_offload": false
      }
    },
    "2": {
      "class_type": "CogVideoCLIPEncode",
      "inputs": {
        "prompt": "__PROMPT__",
        "negative_prompt": "worst quality, blurry, distorted, watermark",
        "model": ["1", 0]
      }
    },
    "3": {
      "class_type": "CogVideoSampler",
      "inputs": {
        "model": ["1", 0],
        "conditioning": ["2", 0],
        "seed": -1,
        "steps": 50,
        "cfg": 6.0,
        "width": __WIDTH__,
        "height": __HEIGHT__,
        "num_frames": __FRAMES__,
        "fps": 8,
        "scheduler": "CogVideoXDPMScheduler"
      }
    },
    "4": {
      "class_type": "CogVideoVAEDecode",
      "inputs": {
        "samples": ["3", 0],
        "model": ["1", 0],
        "enable_vae_tiling": true
      }
    },
    "5": {
      "class_type": "SaveAnimatedWEBP",
      "inputs": {
        "images": ["4", 0],
        "filename_prefix": "cogvideox",
        "fps": 8,
        "lossless": false,
        "quality": 90
      }
    }
  }
}
