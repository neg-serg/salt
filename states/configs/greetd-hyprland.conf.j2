{%- from 'host_config.jinja' import host -%}
# Greeter Hyprland config — minimal session for quickshell login screen

# Monitor: match main session resolution
{% if host.display %}
monitorv2 {
    output = {{ host.primary_output }}
    mode = {{ host.display }}
    position = 0x0
    scale = {{ host.greetd_scale }}
    vrr = 3
    bitdepth = 10
}
# Disable all other outputs during greeter
monitor = , disable
{% endif %}

input {
    kb_layout = us,ru
    repeat_rate = 35
    repeat_delay = 250
}

misc {
    force_default_wallpaper = 0
    disable_hyprland_logo = true
}

animations {
    enabled = false
}

decoration {
    blur {
        enabled = false
    }
    shadow {
        enabled = false
    }
}

# Cursor: match main session theme
env = XCURSOR_THEME,{{ host.cursor_theme }}
env = XCURSOR_SIZE,{{ host.cursor_size }}
env = HYPRCURSOR_THEME,{{ host.cursor_theme }}
env = HYPRCURSOR_SIZE,{{ host.cursor_size }}

# Debug: trace aquamarine (libaquamarine) and enable Hyprland stdout logs
# The greeter Hyprland segfaults in libaquamarine during shutdown — these help diagnose it
env = AQ_TRACE,1
debug {
    enable_stdout_logs = true
}

exec-once = qs -p ~/.config/quickshell/greeter/greeter.qml
