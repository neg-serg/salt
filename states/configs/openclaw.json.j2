{
  "agents": {
    "defaults": {
      "model": {
        "primary": "proxypilot/claude-sonnet-4-6",
        "fallbacks": [
          "proxypilot/claude-opus-4-6"
        ]
      },
      "sandbox": {
        "mode": "off"
      }
    },
    "list": [
      {
        "id": "main",
        "name": "Main (Owner)",
        "tools": {
          "profile": "full"
        }
      },
      {
        "id": "guest",
        "name": "Guest",
        "tools": {
          "profile": "minimal",
          "deny": ["exec", "browser", "gateway", "cron"]
        }
      }
    ]
  },

  "models": {
    "mode": "merge",
    "providers": {
      "proxypilot": {
        "baseUrl": "http://127.0.0.1:8317",
        "apiKey": {{ proxy_key | tojson }},
        "api": "openai-completions",
        "models": [
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6",
            "contextWindow": 200000,
            "maxTokens": 16384
          },
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus 4.6",
            "contextWindow": 200000,
            "maxTokens": 16384
          }
        ]
      }
    }
  },

  "gateway": {
    "mode": "local",
    "port": 18789,
    "auth": {
      "mode": "token"
    },
    "reload": {
      "mode": "hybrid",
      "debounceMs": 300
    }
  }
{%- if telegram_token %},

  "session": {
    "dmScope": "per-channel-peer"
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": {{ telegram_token | tojson }},
      "dmPolicy": "allowlist",
      "allowFrom": [{{ telegram_uid | tojson }}, {{ telegram_uid_levra | tojson }}, {{ telegram_uid_guest2 | tojson }}],
      "groupPolicy": "disabled"
    }
  },

  "bindings": [
    {
      "agentId": "guest",
      "match": {
        "channel": "telegram",
        "peer": { "kind": "direct", "id": "tg:{{ telegram_uid_levra }}" }
      }
    },
    {
      "agentId": "guest",
      "match": {
        "channel": "telegram",
        "peer": { "kind": "direct", "id": "tg:{{ telegram_uid_guest2 }}" }
      }
    }
  ]
{%- endif %}
}
