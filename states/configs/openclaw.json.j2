{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-opus-4-6-20251022",
        "fallbacks": [
          "anthropic/claude-sonnet-4-6-20250514"
        ]
      },
      "sandbox": {
        "mode": "off"
      }
    }
  },

  "models": {
    "mode": "merge",
    "providers": {
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "apiKey": {{ anthropic_key | tojson }},
        "api": "anthropic-messages",
        "models": [
          {
            "id": "claude-opus-4-6-20251022",
            "name": "Claude Opus 4.6",
            "contextWindow": 200000,
            "maxTokens": 16384
          },
          {
            "id": "claude-sonnet-4-6-20250514",
            "name": "Claude Sonnet 4.6",
            "contextWindow": 200000,
            "maxTokens": 16384
          }
        ]
      }
    }
  },

  "gateway": {
    "mode": "local",
    "port": 18789,
    "auth": {
      "mode": "token"
    },
    "reload": {
      "mode": "hybrid",
      "debounceMs": 300
    }
  }
{%- if telegram_token %},

  "session": {
    "dmScope": "per-channel-peer"
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": {{ telegram_token | tojson }},
      "dmPolicy": "allowlist",
      "allowFrom": [{{ telegram_uid | tojson }}],
      "groupPolicy": "disabled"
    }
  }
{%- endif %}
}
