{#- Quadlet container unit template for ProxyPilot LLM proxy
    Rendered by container_service macro. Context:
      catalog_entry:    dict from service_catalog.yaml[proxypilot]
      image:            fully-resolved localhost/proxypilot reference
      expanded_mounts:  list of {host, container, mode} with ~-expansion applied
      user_scope:       True (rootless user-scoped Quadlet)
-#}
[Unit]
Description=ProxyPilot local AI proxy (containerized)
Documentation=https://github.com/Finesssee/ProxyPilot
After=network-online.target
Wants=network-online.target
# StartLimit* keys belong in [Unit] per systemd.unit(5).
StartLimitBurst=5
StartLimitIntervalSec=60

[Container]
Image={{ image }}
ContainerName=proxypilot
PublishPort=127.0.0.1:{{ catalog_entry.port }}:8317
{% for m in expanded_mounts -%}
Volume={{ m.host }}:{{ m.container }}:{{ m.mode }}
{% endfor -%}
{% if catalog_entry.env_file -%}
EnvironmentFile={{ catalog_entry.env_file }}
{% endif -%}
# ProxyPilot reads config from the bind-mounted path
Exec=proxypilot -config /config/config.yaml
# Health check — ProxyPilot has a /health endpoint
HealthCmd=curl -sf http://127.0.0.1:8317/health >/dev/null 2>&1 || exit 1
HealthInterval=5s
HealthStartPeriod=10s
HealthRetries=3
HealthTimeout=5s
Notify=healthy

[Service]
# Bounded restart policy: up to 5 failures in 60s → unit enters failed state
Restart=on-failure
RestartSec=5
TimeoutStartSec=30

[Install]
WantedBy=default.target
