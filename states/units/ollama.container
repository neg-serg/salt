{#- Quadlet container unit template for Ollama (feature 087-containerize-services).
    Rendered by container_service macro; context contains:
      catalog_entry:    dict from service_catalog.yaml[ollama]
      image:            fully-resolved registry/image@sha256:... reference
      expanded_mounts:  list of {host, container, mode} with ~-expansion applied
      user_scope:       False (system scope per FR-017)
-#}
[Unit]
Description=Ollama LLM inference server (containerized)
Documentation=https://github.com/ollama/ollama
After=network-online.target local-fs.target mnt-one.mount
Wants=network-online.target
Requires=mnt-one.mount
# Bounded restart policy per FR-015: up to 5 failures in 60s → unit enters
# failed state. No silent fallback to native. These two keys live in [Unit]
# per systemd.unit(5) — placing them in [Service] causes systemd-analyze
# and the runtime generator to log "Unknown key ... in section [Service]".
StartLimitBurst=5
StartLimitIntervalSec=60

[Container]
Image={{ image }}
ContainerName=ollama
PublishPort=127.0.0.1:{{ catalog_entry.port }}:11434
{% for m in expanded_mounts -%}
Volume={{ m.host }}:{{ m.container }}:{{ m.mode }}
{% endfor -%}
AddDevice=/dev/kfd
AddDevice=/dev/dri/renderD128
# Numeric GID required: Podman resolves GroupAdd names against the
# container's /etc/group, and the upstream Ollama image does not ship
# a `render` group. Read the host's render GID at render time so the
# container process gets the supplementary group it needs to access
# /dev/kfd and /dev/dri/renderD128 even if those nodes were not 666.
GroupAdd={{ salt['cmd.run_stdout']("getent group render | cut -d: -f3", python_shell=True) }}
Environment=OLLAMA_HOST=0.0.0.0:11434
# The upstream Ollama image has neither curl nor wget installed,
# only /usr/bin/ollama itself. `ollama list` queries the local
# server's /api/tags endpoint and exits non-zero if the server
# is not reachable — functionally the same as the curl probe
# would be on a fatter image.
HealthCmd=ollama list
HealthInterval=30s
HealthRetries=3
HealthTimeout=5s
Notify=healthy

[Service]
# Fail-loud GPU preflight checks (FR-007, research Decision 2).
# If either device node is missing the unit goes straight to `failed` state
# before Podman is invoked. HealthCmd above covers ongoing liveness only — it
# cannot detect GPU absence because /api/tags responds even on CPU-only startup.
ExecStartPre=/usr/bin/test -e /dev/kfd
ExecStartPre=/usr/bin/test -e /dev/dri/renderD128
# Bounded restart policy per FR-015: up to 5 failures in 60s → unit enters
# failed state. No silent fallback to native.
Restart=on-failure
RestartSec=5
# TimeoutStartSec generous for cold-start model memory-map load on 7900 XTX.
TimeoutStartSec=120

[Install]
WantedBy=multi-user.target
