{# GitHub release macros: github_tar, github_release_system, github_release_to #}

{% from '_macros_common.jinja' import user as _user, home as _home, retry_attempts as _retry_attempts, retry_interval as _retry_interval, ver_dir as _ver_dir, sys_ver_dir as _sys_ver_dir %}

{# Download tar.gz, extract single binary to ~/.local/bin/.
   version: when set, enables update-on-version-bump via version file.
   Usage: {{ github_tar('eza', 'https://github.com/.../eza_x86_64.tar.gz') }}
          {{ github_tar('tool', '...', version=ver.tool) }}
#}
{%- macro github_tar(name, url, version=None, hash=None, user=_user, home=_home) -%}
{%- set _creates = home ~ '/.local/bin/' ~ name -%}
install_{{ name | replace('-', '_') }}:
  cmd.run:
    - name: |
        set -eo pipefail
        _td=$(mktemp -d)
        trap 'rm -rf "$_td"' EXIT
        curl -fsSL '{{ url }}' -o "$_td/archive.tar.gz"
{%- if hash %}
        echo '{{ hash }}  '"$_td/archive.tar.gz" | sha256sum -c --strict
{%- endif %}
        tar -xzf "$_td/archive.tar.gz" -C "$_td"
        find "$_td" -name '{{ name }}' -type f -exec install -m 0755 {} ~/.local/bin/{{ name }} \;
{%- if version %}
        mkdir -p {{ _ver_dir }} && echo '{{ version }}' > {{ _ver_dir }}/{{ name }}
{%- endif %}
    - runas: {{ user }}
    - shell: /bin/bash
{%- if version %}
    - unless: test -f {{ _creates }} && test -f {{ _ver_dir }}/{{ name }} && rg -qx '{{ version }}' {{ _ver_dir }}/{{ name }}
{%- else %}
    - creates: {{ _creates }}
{%- endif %}
    - parallel: True
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- endmacro -%}

{# Download latest GitHub release asset to /usr/local/bin/ (system-level).
   Like github_release but runs as root, no runas. Supports zip and tar.gz.
   src_bin: filename of the binary inside the archive (default: name).
   Usage: {{ github_release_system('loki', 'grafana/loki', 'loki-linux-amd64.zip', src_bin='loki-linux-amd64') }}
          {{ github_release_system('adguardhome', 'AdguardTeam/AdGuardHome', 'AdGuardHome_linux_amd64.tar.gz', src_bin='AdGuardHome', format='tar.gz') }}
#}
{%- macro github_release_system(name, repo, asset, src_bin=None, format='zip', tag=None, hash=None, version=None, dest='/usr/local/bin') -%}
{%- set source_bin = src_bin or name -%}
{%- set _creates = dest ~ '/' ~ name -%}
install_{{ name | replace('-', '_') }}:
  cmd.run:
    - name: |
        set -eo pipefail
        _td=$(mktemp -d)
        trap 'rm -rf "$_td"' EXIT
{%- if tag %}
        TAG="{{ tag }}"
{%- else %}
        TAG=$(curl -fsSIL -o /dev/null -w '%{url_effective}' https://github.com/{{ repo }}/releases/latest | rg -oP '[^/]+$')
{%- endif %}
{%- if format == 'zip' %}
        curl -fsSL "https://github.com/{{ repo }}/releases/download/${TAG}/{{ asset }}" -o "$_td/archive.zip"
{%- if hash %}
        echo '{{ hash }}  '"$_td/archive.zip" | sha256sum -c --strict
{%- endif %}
        unzip -o "$_td/archive.zip" -d "$_td"
        install -m 0755 "$_td/{{ source_bin }}" {{ dest }}/{{ name }}
{%- elif format == 'tar.gz' %}
        curl -fsSL "https://github.com/{{ repo }}/releases/download/${TAG}/{{ asset }}" -o "$_td/archive.tar.gz"
{%- if hash %}
        echo '{{ hash }}  '"$_td/archive.tar.gz" | sha256sum -c --strict
{%- endif %}
        tar -xzf "$_td/archive.tar.gz" -C "$_td"
        find "$_td" -maxdepth 3 -name '{{ source_bin }}' -type f -exec install -m 0755 {} {{ dest }}/{{ name }} \;
{%- endif %}
{%- if version %}
        mkdir -p {{ _sys_ver_dir }} && echo '{{ version }}' > {{ _sys_ver_dir }}/{{ name }}
{%- endif %}
    - shell: /bin/bash
{%- if version %}
    - unless: test -f {{ _creates }} && test -f {{ _sys_ver_dir }}/{{ name }} && rg -qx '{{ version }}' {{ _sys_ver_dir }}/{{ name }}
{%- else %}
    - creates: {{ _creates }}
{%- endif %}
    - parallel: True
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- endmacro -%}

{# Download latest GitHub release asset to an arbitrary directory.
   Supports single file downloads and ZIP extraction via format parameter.
   format: 'file' (default) downloads asset directly; 'zip' extracts ZIP contents to dest.
   state_id: explicit Salt state ID (caller must ensure uniqueness).
   creates: idempotency guard (defaults to dest/name for file, required for zip).
   require: optional file state ID to depend on.
   Usage: {{ github_release_to('mpv_script_mpris_so', 'mpris.so', 'hoyon/mpv-mpris', 'mpris.so', mpv_scripts_dir, require='mpv_scripts_dir') }}
          {{ github_release_to('mpv_plugin_uosc', 'uosc', 'tomasklaen/uosc', 'uosc.zip', '~/.config/mpv', format='zip', creates=mpv_scripts_dir ~ '/uosc', require='mpv_scripts_dir') }}
#}
{%- macro github_release_to(state_id, name, repo, asset, dest, format='file', tag=None, hash=None, version=None, creates=None, require=None, user=_user) -%}
{%- set _creates = creates or (dest ~ '/' ~ name) -%}
{{ state_id }}:
  cmd.run:
    - name: |
        set -eo pipefail
{%- if tag %}
        TAG="{{ tag }}"
{%- else %}
        TAG=$(curl -fsSIL -o /dev/null -w '%{url_effective}' https://github.com/{{ repo }}/releases/latest | rg -oP '[^/]+$')
{%- endif %}
{%- if format == 'zip' %}
        _td=$(mktemp -d)
        trap 'rm -rf "$_td"' EXIT
        curl -fsSL "https://github.com/{{ repo }}/releases/download/${TAG}/{{ asset }}" -o "$_td/archive.zip"
{%- if hash %}
        echo '{{ hash }}  '"$_td/archive.zip" | sha256sum -c --strict
{%- endif %}
        unzip -qo "$_td/archive.zip" -d {{ dest }}
{%- else %}
        curl -fsSL "https://github.com/{{ repo }}/releases/download/${TAG}/{{ asset }}" -o '{{ dest }}/{{ name }}'
{%- if hash %}
        echo '{{ hash }}  {{ dest }}/{{ name }}' | sha256sum -c --strict
{%- endif %}
{%- endif %}
{%- if version %}
        mkdir -p {{ _ver_dir }} && echo '{{ version }}' > {{ _ver_dir }}/{{ name }}
{%- endif %}
    - runas: {{ user }}
    - shell: /bin/bash
{%- if version %}
    - unless: test -e {{ _creates }} && test -f {{ _ver_dir }}/{{ name }} && rg -qx '{{ version }}' {{ _ver_dir }}/{{ name }}
{%- else %}
    - creates: {{ _creates }}
{%- endif %}
    - parallel: True
{%- if require %}
    - require:
      - file: {{ require }}
{%- endif %}
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- endmacro -%}
