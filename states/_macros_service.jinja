{# Service-related macros: ensure_dir, udev_rule, ensure_running, service_stopped, service_with_healthcheck, unit_override, config_replace_with_service_control, service_with_unit, service_with_unit_and_healthcheck, user_service_file, user_unit_override, user_service_enable, user_linger, managed_sysusers_line, managed_tmpfiles_line, managed_identity_guard, managed_path_guard #}

{% from '_macros_common.jinja' import user as _user, home as _home, healthcheck_timeout as _healthcheck_timeout, host, retry_attempts as _retry_attempts, retry_interval as _retry_interval %}

{# Shared env block for systemctl --user commands (daemon-reload, enable, restart, disable) #}
{%- set _systemctl_env = [
  'XDG_RUNTIME_DIR: ' ~ host.runtime_dir,
  'DBUS_SESSION_BUS_ADDRESS: unix:path=' ~ host.runtime_dir ~ '/bus',
] -%}

{# Resolve symbolic inventory values for managed systemd resources.
   Currently supports __CURRENT_USER__ for user-owned tmpfiles entries.
#}
{%- macro managed_resource_value(value) -%}
{%- if value == '__CURRENT_USER__' -%}
{{ _user }}
{%- else -%}
{{ value }}
{%- endif -%}
{%- endmacro -%}

{%- macro managed_mode_value(mode) -%}
{%- set _mode = managed_resource_value(mode)|string -%}
{{ _mode[1:] if _mode.startswith('0') else _mode }}
{%- endmacro -%}

{# Render a single sysusers.d entry from states/data/managed_resources.yaml.
   Keep long-lived service account names and homes stable; new services should be
   added to the inventory rather than using bespoke user.present states.
#}
{%- macro managed_sysusers_line(entry) -%}
u {{ managed_resource_value(entry.user) }} - "{{ entry.get('gecos', 'Salt managed service account') }}" {{ managed_resource_value(entry.home) }} {{ entry.get('shell', '/usr/sbin/nologin') }}
{%- endmacro -%}

{# Guard used by states/systemd_resources.sls to repair missing service accounts
   without rerunning systemd-sysusers on every apply.
#}
{%- macro managed_identity_guard(entry) -%}
getent passwd {{ managed_resource_value(entry.user) }} >/dev/null && getent group {{ managed_resource_value(entry.group) }} >/dev/null
{%- endmacro -%}

{# Render a single tmpfiles.d entry from states/data/managed_resources.yaml.
   Prefer this shared inventory for long-lived service resources over one-off
   tmpfiles snippets embedded inside individual states.
#}
{%- macro managed_tmpfiles_line(entry) -%}
{{ entry.type }} {{ managed_resource_value(entry.path) }} {{ entry.mode }} {{ managed_resource_value(entry.user) }} {{ managed_resource_value(entry.group) }} {{ entry.get('age', '-') }} {{ managed_resource_value(entry.get('argument', '-')) }}
{%- endmacro -%}

{# Guard used by states/systemd_resources.sls to recreate missing or drifted
   managed paths while keeping cmd.run states explicitly idempotent.
#}
{%- macro managed_path_guard(entry) -%}
{%- set _path = managed_resource_value(entry.path) -%}
{%- set _user_name = managed_resource_value(entry.user) -%}
{%- set _group_name = managed_resource_value(entry.group) -%}
{%- set _mode = managed_mode_value(entry.mode) -%}
{%- if entry.type == 'd' -%}
test -d {{ _path }} && test "$(stat -c '%U:%G:%a' {{ _path }})" = "{{ _user_name }}:{{ _group_name }}:{{ _mode }}"
{%- elif entry.type == 'p' -%}
test -p {{ _path }} && test "$(stat -c '%U:%G:%a' {{ _path }})" = "{{ _user_name }}:{{ _group_name }}:{{ _mode }}"
{%- elif entry.type == 'f' -%}
test -f {{ _path }} && test "$(stat -c '%U:%G:%a' {{ _path }})" = "{{ _user_name }}:{{ _group_name }}:{{ _mode }}"
{%- elif entry.type == 'L' -%}
test -L {{ _path }} && test "$(readlink {{ _path }})" = "{{ managed_resource_value(entry.get('argument', '-')) }}"
{%- else -%}
test -e {{ _path }}
{%- endif -%}
{%- endmacro -%}

{# Create directory with user ownership and makedirs.
   Covers the common pattern of user-owned directories (user/group/makedirs: True).
   mode: optional file mode (e.g. '0700'); require: optional list of state requisites.
   Usage: {{ ensure_dir('steam_library_dir', '/mnt/zero/steam/steamapps') }}
          {{ ensure_dir('ssh_dir', home ~ '/.ssh', mode='0700') }}
          {{ ensure_dir('ollama_models_dir', '/mnt/one/ollama/models', require=['mount: mount_one']) }}
#}
{%- macro ensure_dir(name, path, mode=None, require=None, user=_user) -%}
{{ name }}:
  file.directory:
    - name: {{ path }}
    - user: {{ user }}
    - group: {{ user }}
    - makedirs: True
{%- if mode %}
    - mode: '{{ mode }}'
{%- endif %}
{%- if require %}
    - require:
{%- for req in require %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{# Deploy udev rule file + reload rules on change.
   Supports source (salt:// path) or inline contents.
   Emits two states: {{ name }} (file.managed) and {{ name }}_reload (udevadm).
   Usage: {{ udev_rule('custom_udev_rules', '/etc/udev/rules.d/99-custom.rules', source='salt://configs/udev-custom.rules') }}
          {{ udev_rule('kanata_udev_rule', '/etc/udev/rules.d/99-uinput.rules', contents='KERNEL=="uinput", ...') }}
#}
{%- macro udev_rule(name, path, source=None, contents=None) -%}
{{ name }}:
  file.managed:
    - name: {{ path }}
{%- if contents is not none %}
    - contents: '{{ contents }}'
{%- elif source %}
    - source: {{ source }}
{%- endif %}
    - mode: '0644'

{{ name }}_reload:
  cmd.run:
    - name: udevadm control --reload-rules && udevadm trigger
    - onchanges:
      - file: {{ name }}
{%- endmacro -%}

{# Clear failed state + ensure service is running with config watches.
   Emits two states: {{ name }}_reset_failed and {{ name }}_running.
   service: systemd service name override (default: name).
   Usage: {{ ensure_running('unbound', watch=['file: unbound_config']) }}
          {{ ensure_running('avahi', service='avahi-daemon', watch=['file: avahi_config']) }}
#}
{%- macro ensure_running(name, service=None, watch=None) -%}
{%- set svc = service or name -%}
{{ name }}_reset_failed:
  cmd.run:
    - name: systemctl reset-failed {{ svc }} 2>/dev/null; true
    - onlyif: systemctl is-failed {{ svc }}
    - require:
      - service: {{ name }}_enabled

{{ name }}_running:
  service.running:
    - name: {{ svc }}
{%- if watch %}
    - watch:
{%- for w in watch %}
      - {{ w }}
{%- endfor %}
{%- endif %}
    - require:
      - service: {{ name }}_enabled
      - cmd: {{ name }}_reset_failed
{%- endmacro -%}

{# Stop and disable a service (service.dead + enable: False), or just disable (service.disabled).
   stop: True (default) = stop + disable; False = disable only (leave running until reboot).
   Usage: {{ service_stopped('disable_tuned', 'tuned') }}
          {{ service_stopped('samba_not_enabled', 'smb', stop=False, requires=['file: samba_config']) }}
#}
{%- macro service_stopped(name, svc, stop=True, requires=None, onlyif=None) -%}
{{ name }}:
{%- if stop %}
  service.dead:
    - name: {{ svc }}
    - enable: False
{%- else %}
  service.disabled:
    - name: {{ svc }}
{%- endif %}
{%- if onlyif %}
    - onlyif: {{ onlyif }}
{%- endif %}
{%- if requires %}
    - require:
{%- for req in requires %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{# Apply one or more file.replace mutations and control the affected service only on change.
   replacements: list of tuples (state_id, pattern, repl[, flags]). Defaults flags to MULTILINE.
   action: 'restart' (default) or 'reload' to choose the post-change service.running behavior.
   Emits N file.replace states, {{ name }}_stop_before_change, and {{ name }}_<action>_after_change.
   Usage: {{ config_replace_with_service_control('transmission_settings', transmission_cfg, 'transmission', replacements, requires=['cmd: install_transmission'], service_require=['service: transmission_enabled']) }}
#}
{%- macro config_replace_with_service_control(name, path, service, replacements, requires=None, service_require=None, action='restart') -%}
{%- set control_action = 'reload' if action == 'reload' else 'restart' -%}
{% for replacement in replacements %}
  {% set state_id = replacement[0] %}
  {% set pattern = replacement[1] %}
  {% set repl = replacement[2] %}
  {% set flags = replacement[3] if replacement|length > 3 else 'MULTILINE' %}
{{ state_id }}:
  file.replace:
    - name: {{ path }}
    - pattern: '{{ pattern }}'
    - repl: '{{ repl }}'
    - flags: {{ flags }}
{%- if requires %}
    - require:
{%- for req in requires %}
      - {{ req }}
{%- endfor %}
{%- endif %}

{% endfor %}
{{ name }}_stop_before_change:
  service.dead:
    - name: {{ service }}
    - prereq:
{%- for replacement in replacements %}
      - file: {{ replacement[0] }}
{%- endfor %}

{{ name }}_{{ control_action }}_after_change:
  service.running:
    - name: {{ service }}
{%- if control_action == 'reload' %}
    - reload: True
{%- endif %}
    - watch:
{%- for replacement in replacements %}
      - file: {{ replacement[0] }}
{%- endfor %}
{%- if service_require %}
    - require:
{%- for req in service_require %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{# Restart service and poll a health-check command until it succeeds.
   Skips entirely if the check already passes (unless guard).
   check_cmd: shell command that returns 0 when service is ready (explicit override).
   catalog: imported service_catalog.yaml dict — when provided and check_cmd is omitted,
   the macro looks up `service` in the catalog and constructs the healthcheck automatically:
     - catalog[service].health_cmd → use directly (non-HTTP checks like unbound-control)
     - catalog[service].port + health_path → curl -sf http://<host>:<port><path> >/dev/null 2>&1
   timeout: seconds to poll (default: healthcheck_timeout). Catalog entry timeout overrides default.
   Usage: {{ service_with_healthcheck('ollama_start', 'ollama', catalog=catalog, requires=['service: ollama_enabled']) }}
          {{ service_with_healthcheck('custom_start', 'custom', 'my-check-cmd', requires=[...]) }}
#}
{%- macro service_with_healthcheck(name, service, check_cmd=None, timeout=_healthcheck_timeout, requires=None, catalog=None) -%}
{#- Resolve check_cmd from catalog when not explicitly provided -#}
{%- if check_cmd is none and catalog is not none and service in catalog -%}
  {%- set _entry = catalog[service] -%}
  {%- if _entry.get('health_cmd') -%}
    {%- set check_cmd = _entry.health_cmd -%}
  {%- elif _entry.get('port') and _entry.get('health_path') -%}
    {%- set _host = _entry.get('health_host', '127.0.0.1') -%}
    {%- set check_cmd = 'curl -sf http://' ~ _host ~ ':' ~ _entry.port ~ _entry.health_path ~ ' >/dev/null 2>&1' -%}
  {%- endif -%}
  {%- if _entry.get('timeout') -%}
    {%- set timeout = _entry.timeout -%}
  {%- endif -%}
{%- endif -%}
{{ name }}:
  cmd.run:
    - name: |
        if ! systemctl is-active --quiet {{ service }}; then
          systemctl daemon-reload
          systemctl restart {{ service }}
        fi
        for i in $(seq 1 {{ timeout }}); do
          {{ check_cmd }} && exit 0
          sleep 1
        done
        echo "{{ service }} failed to start within {{ timeout }}s" >&2
        exit 1
    - shell: /bin/bash
    - unless: {{ check_cmd }}
{%- if requires %}
    - require:
{%- for req in requires %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{# Deploy systemd unit drop-in override + trigger daemon-reload on change.
   Creates parent .d/ directory automatically via makedirs.
   Emits two states: {{ name }} (file.managed) and {{ name }}_reload (daemon-reload).
   Usage: {{ unit_override('netdata_override', 'netdata.service', 'salt://units/netdata-override.conf') }}
          {{ unit_override('unbound_restart_override', 'unbound.service', 'salt://units/unbound-restart-override.conf', filename='restart.conf', requires=['cmd: install_unbound']) }}
#}
{%- macro unit_override(name, service, source, filename='override.conf', requires=None) -%}
{{ name }}:
  file.managed:
    - name: /etc/systemd/system/{{ service }}.d/{{ filename }}
    - source: {{ source }}
    - makedirs: True
    - mode: '0644'
{%- if requires %}
    - require:
{%- for req in requires %}
      - {{ req }}
{%- endfor %}
{%- endif %}

{{ name }}_reload:
  cmd.run:
    - name: systemctl daemon-reload
    - onchanges:
      - file: {{ name }}
{%- endmacro -%}

{# Deploy systemd user unit file (~/.config/systemd/user/) from units/user/.
   source: override default salt://units/user/ path for units stored elsewhere.
   Usage: {{ user_service_file('mbsync_gmail_service', 'mbsync-gmail.service') }}
          {{ user_service_file('mpdas_service_file', 'mpdas.service', source='salt://dotfiles/dot_config/systemd/user/mpdas.service') }}
#}
{%- macro user_service_file(name, filename, source=None, template=None, context=None, user=_user, home=_home) -%}
{{ name }}:
  file.managed:
    - name: {{ home }}/.config/systemd/user/{{ filename }}
    - source: {{ source or ('salt://units/user/' ~ filename) }}
{%- if template %}
    - template: {{ template }}
{%- endif %}
{%- if context %}
    - context:
{%- for key, value in context.items() %}
        {{ key }}: {{ value }}
{%- endfor %}
{%- endif %}
    - user: {{ user }}
    - group: {{ user }}
    - mode: '0644'
    - makedirs: True

{{ name }}_daemon_reload:
  cmd.run:
    - name: systemctl --user daemon-reload
    - runas: {{ user }}
    - env:
{%- for entry in _systemctl_env %}
      - {{ entry }}
{%- endfor %}
    - onchanges:
      - file: {{ name }}
{%- endmacro -%}

{# Deploy systemd user unit drop-in override + trigger daemon-reload on change.
   Analogous to unit_override (system) but for user services (~/.config/systemd/user/).
   Emits two states: {{ name }} (file.managed) and {{ name }}_daemon_reload (cmd.run).
   Usage: {{ user_unit_override('mpdris2_user_service', 'mpDris2.service', contents=override_text) }}
          {{ user_unit_override('foo_override', 'foo.service', source='salt://units/user/foo-override.conf') }}
#}
{%- macro user_unit_override(name, service, source=None, contents=None, filename='override.conf', requires=None, user=_user, home=_home) -%}
{{ name }}:
  file.managed:
    - name: {{ home }}/.config/systemd/user/{{ service }}.d/{{ filename }}
    - user: {{ user }}
    - group: {{ user }}
    - mode: '0644'
    - makedirs: True
{%- if contents is not none %}
    - contents: |
{{ contents | trim | indent(8, first=True) }}
{%- elif source %}
    - source: {{ source }}
{%- endif %}
{%- if requires %}
    - require:
{%- for req in requires %}
      - {{ req }}
{%- endfor %}
{%- endif %}

{{ name }}_daemon_reload:
  cmd.run:
    - name: systemctl --user daemon-reload
    - runas: {{ user }}
    - env:
{%- for entry in _systemctl_env %}
      - {{ entry }}
{%- endfor %}
    - onchanges:
      - file: {{ name }}
{%- endmacro -%}

{# Enable systemd user service(s) with proper D-Bus/XDG environment.
   Handles daemon-reload, enable, enable --now, and idempotency guards.
   services: list of units to `enable` (default []). start_now: list of units to `enable --now` (default []).
   daemon_reload: prepend daemon-reload (default False). check: 'enabled' (default) or 'active' for unless guard.
   onlyif: extra guard (e.g. package installed check). requires: list of state requisites.
   Usage: {{ user_service_enable('kanata_enabled', ['kanata.service'], daemon_reload=True, requires=['cmd: install_kanata', 'file: kanata_service']) }}
          {{ user_service_enable('mpd_enabled', start_now=['mpd.service'], check='active', onlyif='grep -qxF mpd ' ~ pkg_list) }}
          {{ user_service_enable('enable_user_services', svc_list, start_now=timer_list, daemon_reload=True, requires=req_list) }}
#}
{%- macro user_service_enable(name, services=None, start_now=None, daemon_reload=False, check='enabled', onlyif=None, requires=None, user=_user) -%}
{%- set svc_list = services if services else [] -%}
{%- set now_list = start_now if start_now else [] -%}
{%- set all_units = svc_list + now_list -%}
{{ name }}:
  cmd.run:
    - name: |
{%- if not all_units and not daemon_reload %}
        /usr/bin/true
{%- else %}
        set -e
{%- if daemon_reload %}
        systemctl --user daemon-reload
{%- endif %}
{%- for svc in svc_list %}
        systemctl --user is-{{ check }} '{{ svc }}' >/dev/null 2>&1 || systemctl --user enable '{{ svc }}'
{%- endfor %}
{%- for svc in now_list %}
        systemctl --user is-active '{{ svc }}' >/dev/null 2>&1 || systemctl --user enable --now '{{ svc }}'
{%- endfor %}
{%- endif %}
    - shell: /bin/bash
    - runas: {{ user }}
    - env:
{%- for entry in _systemctl_env %}
      - {{ entry }}
{%- endfor %}
{%- if all_units %}
    - unless: |
        set -e
        export XDG_RUNTIME_DIR={{ host.runtime_dir }}
        export DBUS_SESSION_BUS_ADDRESS=unix:path={{ host.runtime_dir }}/bus
{%- for svc in svc_list %}
        systemctl --user is-{{ check }} '{{ svc }}' >/dev/null 2>&1
{%- endfor %}
{%- for svc in now_list %}
        systemctl --user is-enabled '{{ svc }}' >/dev/null 2>&1
{%- endfor %}
{%- endif %}
{%- if onlyif %}
    - onlyif: {{ onlyif }}
{%- endif %}
{%- if requires %}
    - require:
{%- for req in requires %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{# Deploy user unit file + enable service in a single call.
   Combines user_service_file() + user_service_enable() with internal require chain.
   services: list of units to enable (default [filename]). start_now: list to enable --now (default []).
   Usage: {{ user_service_with_unit('kanata', 'kanata.service', start_now=['kanata.service'], requires=['cmd: install_kanata']) }}
          {{ user_service_with_unit('mpdas', 'mpdas.service', source='salt://dotfiles/dot_config/systemd/user/mpdas.service') }}
#}
{%- macro user_service_with_unit(name, filename, source=None, services=None, start_now=None, requires=None, user=_user, home=_home) -%}
{%- set _svc_list = services if services is not none else [filename] -%}
{%- set _now_list = start_now if start_now else [] -%}
{%- set _file_id = name ~ '_service' -%}
{{ user_service_file(_file_id, filename, source=source, user=user, home=home) }}

{%- set _reqs = ['file: ' ~ _file_id, 'cmd: ' ~ _file_id ~ '_daemon_reload'] -%}
{%- if requires %}
{%- for req in requires %}
{%- set _ = _reqs.append(req) %}
{%- endfor %}
{%- endif %}

{{ user_service_enable(name ~ '_enabled', services=_svc_list, start_now=_now_list, requires=_reqs, user=user) }}
{%- endmacro -%}

{# Restart a systemd user service with proper environment wiring.
   Usage: {{ user_service_restart('restart_proxypilot', 'proxypilot.service', onlyif='systemctl --user is-active proxypilot.service >/dev/null 2>&1', requires=['file: proxypilot_config']) }}
#}
{%- macro user_service_restart(name, service, onlyif=None, requires=None, onchanges=None, user=_user) -%}
{{ name }}:
  cmd.run:
    - name: systemctl --user restart {{ service }}
    - runas: {{ user }}
    - env:
{%- for entry in _systemctl_env %}
      - {{ entry }}
{%- endfor %}
{%- if onlyif %}
    - onlyif: {{ onlyif }}
{%- endif %}
{%- if requires %}
    - require:
{%- for req in requires %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- if onchanges %}
    - onchanges:
{%- for change in onchanges %}
      - {{ change }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{# Disable (and stop) systemd user services only when currently enabled.
   Usage: {{ user_service_disable('disable_mail_services', ['mbsync-gmail.timer', 'imapnotify-gmail.service']) }}
#}
{%- macro user_service_disable(name, units, user=_user) -%}
{{ name }}:
  cmd.run:
    - name: systemctl --user disable --now {{ units | join(' ') }} 2>/dev/null || true
    - runas: {{ user }}
    - env:
{%- for entry in _systemctl_env %}
      - {{ entry }}
{%- endfor %}
    - onlyif: |
        export XDG_RUNTIME_DIR={{ host.runtime_dir }}
        export DBUS_SESSION_BUS_ADDRESS=unix:path={{ host.runtime_dir }}/bus
{%- for unit in units %}
        systemctl --user is-enabled '{{ unit }}' >/dev/null 2>&1 && exit 0
{%- endfor %}
        exit 1
{%- endmacro -%}

{# Enable loginctl lingering for a user (services survive logout).
   Generates a single cmd.run with unless guard.
   Usage: {{ user_linger('nanoclaw_lingering') }}
          {{ user_linger('openclaw_lingering', require=['cmd: install_openclaw']) }}
#}
{%- macro user_linger(name, user=_user, require=None) -%}
{{ name }}:
  cmd.run:
    - name: loginctl enable-linger {{ user }}
    - unless: loginctl show-user {{ user }} 2>/dev/null | grep -q '^Linger=yes'
{%- if require %}
    - require:
{%- for req in require %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{# Deploy systemd unit file + manage service (file + daemon-reload + enable/disable + optional running).
   unit_type: 'service' (default) | 'timer' | 'socket' | etc.
   running: True (default False) to add reset_failed + service.running with watch for auto-restart.
   enabled: True (default) = service.enabled; False = service.disabled; None = skip enable/disable.
   requires: optional list of state requisites (includes daemon-reload as base requirement).
   template: 'jinja' (default None) to render the unit file as a Jinja template.
   context: dict of template variables (default None), used with template='jinja'.
   onlyif: guard for service.enabled (default None), e.g. 'command -v ollama'.
   companion: optional second unit source for service+timer pairs (daemon-reload watches both).
   watch: optional list of extra state requisites to watch (e.g. config files); used with running=True.
   Usage: {{ service_with_unit('loki', 'salt://units/loki.service', running=True, watch=['file: loki_config'], requires=['cmd: install_loki', 'file: loki_config']) }}
          {{ service_with_unit('ollama', 'salt://units/ollama.service', template='jinja', context={'user': user, 'home': home}, onlyif='command -v ollama') }}
          {{ service_with_unit('xray', 'salt://units/xray.service', enabled=False) }}
          {{ service_with_unit('duckdns-update', 'salt://units/duckdns-update.timer', unit_type='timer', enabled=False, companion='salt://units/duckdns-update.service') }}
#}
{%- macro service_with_unit(name, source, unit_type='service', running=False, enabled=True, requires=None, template=None, context=None, onlyif=None, companion=None, watch=None) -%}
{{ name }}_service:
  file.managed:
    - name: /etc/systemd/system/{{ name }}.{{ unit_type }}
    - mode: '0644'
    - source: {{ source }}
{%- if template %}
    - template: {{ template }}
{%- endif %}
{%- if context %}
    - context:
{%- for key, val in context.items() %}
        {{ key }}: {{ val }}
{%- endfor %}
{%- endif %}
{%- if companion %}

{{ name }}_companion:
  file.managed:
    - name: /etc/systemd/system/{{ name }}.{{ 'service' if unit_type != 'service' else 'timer' }}
    - mode: '0644'
    - source: {{ companion }}
{%- if template %}
    - template: {{ template }}
{%- endif %}
{%- if context %}
    - context:
{%- for key, val in context.items() %}
        {{ key }}: {{ val }}
{%- endfor %}
{%- endif %}
{%- endif %}

{{ name }}_daemon_reload:
  cmd.run:
    - name: systemctl daemon-reload
    - onchanges:
      - file: {{ name }}_service
{%- if companion %}
      - file: {{ name }}_companion
{%- endif %}
{%- if enabled is not none %}

{{ name }}_{{ 'enabled' if enabled else 'disabled' }}:
  service.{{ 'enabled' if enabled else 'disabled' }}:
    - name: {{ name }}
{%- if onlyif and enabled %}
    - onlyif: {{ onlyif }}
{%- endif %}
    - require:
      - cmd: {{ name }}_daemon_reload
{%- if requires %}
{%- for req in requires %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- endif %}
{%- if running %}

{{ name }}_reset_failed:
  cmd.run:
    - name: systemctl reset-failed {{ name }} 2>/dev/null; true
    - onlyif: systemctl is-failed {{ name }}
    - require:
      - service: {{ name }}_enabled

{{ name }}_running:
  service.running:
    - name: {{ name }}
    - watch:
      - file: {{ name }}_service
{%- for w in (watch or []) %}
      - {{ w }}
{%- endfor %}
    - require:
      - service: {{ name }}_enabled
      - cmd: {{ name }}_reset_failed
{%- endif %}
{%- endmacro -%}

{# Deploy unit file + manage service + run healthcheck — all in one.
   Combines service_with_unit() + service_with_healthcheck() for the common
   pattern where both are always used together.
   healthcheck_requires: custom requisites for the healthcheck state
     (defaults to ['service: <name>_enabled']).
   catalog/check_cmd: if neither is provided, no healthcheck is generated.
   Usage: {{ service_with_unit_and_healthcheck('loki', 'salt://units/loki.service', running=True, watch=['file: loki_config'], requires=['cmd: install_loki', 'file: loki_config'], catalog=catalog) }}
          {{ service_with_unit_and_healthcheck('ollama', 'salt://units/ollama.service.j2', template='jinja', context={...}, onlyif='command -v ollama', catalog=catalog) }}
#}
{%- macro service_with_unit_and_healthcheck(name, source, unit_type='service', running=False, enabled=True, requires=None, template=None, context=None, onlyif=None, companion=None, watch=None, check_cmd=None, timeout=_healthcheck_timeout, catalog=None, healthcheck_requires=None) -%}
{{ service_with_unit(name, source, unit_type=unit_type, running=running, enabled=enabled, requires=requires, template=template, context=context, onlyif=onlyif, companion=companion, watch=watch) }}
{%- if catalog is not none or check_cmd is not none %}

{{ service_with_healthcheck(name ~ '_start', name, check_cmd=check_cmd, timeout=timeout, catalog=catalog, requires=healthcheck_requires or ['service: ' ~ name ~ '_enabled']) }}
{%- endif %}
{%- endmacro -%}

{# Tilde-expand a bind-mount host path against the caller's home directory.
   Used by container_service() to render absolute host paths in Quadlet Volume= lines.
   '~' alone → home; '~/foo' → home/foo; anything else passes through unchanged.
#}
{%- macro _tilde_expand(raw_path, home_value) -%}
{%- if raw_path == '~' -%}
{{ home_value }}
{%- elif raw_path is string and raw_path.startswith('~/') -%}
{{ home_value }}/{{ raw_path[2:] }}
{%- else -%}
{{ raw_path }}
{%- endif -%}
{%- endmacro -%}

{# Containerized-service supervisor (feature 087-containerize-services).
   Parallel to service_with_unit: deploys a Podman Quadlet .container unit,
   pulls the digest-pinned image, reloads systemd, enables/starts the unit,
   delegates the catalog healthcheck, and schedules bounded native-package
   teardown after the rollback window closes.

   Arguments:
     name            - state ID prefix AND Quadlet unit basename; must match a
                       top-level key in service_catalog.yaml
     catalog_entry   - dict from service_catalog.yaml[name]; MUST include
                       containerized: true
     image_registry  - parsed container_images.yaml map; the macro reads
                       image_registry[catalog_entry.container_image]
     user_scope      - True for rootless user-scoped Quadlet (must match
                       catalog_entry.scope == 'user')
     requires        - extra state requisites appended to the pull state
     watch           - extra state requisites appended to the running state

   Emitted states (see specs/087-containerize-services/contracts/container_service_macro.md
   for the authoritative contract):
     {name}_container, {name}_image_pull, {name}_daemon_reload,
     {name}_enabled (skipped if manual_start), {name}_reset_failed (skipped
     if manual_start), {name}_running (skipped if manual_start),
     {name}_healthcheck (skipped if manual_start), {name}_native_teardown
     (skipped if packages is empty).

   Render-time preconditions (fail loudly if violated):
     1. catalog_entry.containerized == true
     2. catalog_entry.container_image resolves to a key in image_registry
     3. image_registry[...].digest matches sha256:<64 hex> (P1/P2 services);
        null digest is allowed for P3 services but emits ZERO states (the
        upstream-image gate pattern — FR-014 + research Decision 7)
     4. catalog_entry.cutover_mode is 'in_place' or 'blue_green'
     5. user_scope agreement with catalog_entry.scope (FR-017)
     6. gpu == 'amdgpu' implies scope == 'system' (research Decision 2)

   Usage:
     {{ container_service('ollama', catalog.ollama, image_registry,
                          requires=['file: ollama_models_dir', 'mount: mount_one']) }}
     {{ container_service('telethon_bridge', catalog.telethon_bridge, image_registry,
                          user_scope=True,
                          requires=['cmd: install_python_telethon']) }}
#}
{#- Helper: emit a fail_without_changes state that surfaces a precondition
    error at apply time. Render always succeeds so `just validate` is unaffected;
    the error fires only when Salt actually tries to apply a state tree that
    invokes container_service with bad inputs. State-ID embeds the message for
    visibility in `salt-call state.show_sls` output.
#}
{%- macro _cs_fail(name, error_key, message) -%}
container_service_PRECONDITION_FAILED_{{ name }}_{{ error_key }}:
  test.fail_without_changes:
    - name: 'container_service({{ name }}): {{ message }}'
    - failhard: True
{%- endmacro -%}

{%- macro container_service(name, catalog_entry, image_registry, user_scope=False, requires=None, watch=None, quadlet_unit_name=None) -%}
{#- quadlet_unit_name overrides the Quadlet file basename (and therefore the
    generated systemd unit name) when set. Used for blue/green cases where the
    containerized form must coexist with a still-running native unit of the
    same logical service name (Loki is the canonical example). Defaults to
    `name`, which gives the containerized form the same systemd unit name as
    the native form — correct for hard-cutover cases (Ollama, llama_embed,
    Promtail, Grafana, bridges) where only one form runs at a time. -#}
{%- set _quadlet_name = quadlet_unit_name if quadlet_unit_name is not none else name -%}
{#- Precondition 1: containerized flag -#}
{%- if not catalog_entry.get('containerized', False) -%}
{{ _cs_fail(name, 'not_containerized', 'catalog entry missing containerized: true') }}
{%- else -%}
{#- Precondition 2: image_registry lookup -#}
{%- set _image_key = catalog_entry.get('container_image') -%}
{%- if _image_key is none or _image_key not in image_registry -%}
{{ _cs_fail(name, 'image_key_missing', 'container_image "' ~ (_image_key or 'null') ~ '" not found in container_images.yaml') }}
{%- else -%}
{%- set _img = image_registry[_image_key] -%}
{#- Precondition 3: digest check (null digest → emit nothing, P3 upstream-image gate) -#}
{%- if _img.get('digest') is none -%}
{#- Null digest: emit a single no-op state so the branch has something to
    anchor downstream require: chains to, and surface the gate status in the
    apply log. This is the upstream-image gate pattern (research Decision 7). -#}
{{ name }}_container_deferred:
  test.succeed_without_changes:
    - name: {{ name }}
    - comment: >
        container_service({{ name }}): image digest is null in container_images.yaml
        — P3 upstream-image gate is active, no containerized states emitted.
        Flipping features.containers.{{ name }} to true has no effect until a
        non-null digest is committed.
{%- else -%}
{#- Full P1/P2 path: digest present, run remaining preconditions then emit the full state graph -#}
{%- set _digest = _img.digest -%}
{%- set _cutover_mode = catalog_entry.get('cutover_mode') -%}
{%- set _catalog_scope = catalog_entry.get('scope') -%}
{%- set _gpu = catalog_entry.get('gpu', 'none') -%}
{%- set _digest_ok = (_digest is string and _digest.startswith('sha256:') and _digest | length == 71) -%}
{%- set _cutover_ok = _cutover_mode in ['in_place', 'blue_green'] -%}
{%- set _scope_ok = (user_scope and _catalog_scope == 'user') or ((not user_scope) and _catalog_scope == 'system') -%}
{%- set _gpu_ok = not (_gpu == 'amdgpu' and user_scope) -%}
{%- if not _digest_ok -%}
{{ _cs_fail(name, 'bad_digest_format', 'image digest "' ~ _digest ~ '" does not match sha256:<64 hex>; FR-014 violation') }}
{%- elif not _cutover_ok -%}
{{ _cs_fail(name, 'bad_cutover_mode', 'cutover_mode must be in_place or blue_green, got "' ~ (_cutover_mode or 'null') ~ '"') }}
{%- elif not _scope_ok -%}
{{ _cs_fail(name, 'scope_mismatch', 'user_scope=' ~ user_scope ~ ' but catalog scope is "' ~ (_catalog_scope or 'null') ~ '" — FR-017 violation') }}
{%- elif not _gpu_ok -%}
{{ _cs_fail(name, 'gpu_scope_violation', 'gpu=amdgpu requires system scope (research Decision 2)') }}
{%- else -%}
{#- All preconditions passed: resolve paths and image reference -#}
{%- set _full_image = _img.registry ~ '/' ~ _img.image ~ '@' ~ _digest -%}
{%- set _manual_start = catalog_entry.get('manual_start', False) -%}
{%- set _packages = catalog_entry.get('packages', '') -%}
{%- set _cutover_date = catalog_entry.get('cutover_date') -%}
{#- Quadlet file location depends on scope and on quadlet_unit_name override -#}
{%- if user_scope -%}
{%- set _quadlet_path = _home ~ '/.config/containers/systemd/' ~ _quadlet_name ~ '.container' -%}
{%- set _quadlet_source = 'salt://units/user/' ~ _quadlet_name ~ '.container' -%}
{%- else -%}
{%- set _quadlet_path = '/etc/containers/systemd/' ~ _quadlet_name ~ '.container' -%}
{%- set _quadlet_source = 'salt://units/' ~ _quadlet_name ~ '.container' -%}
{%- endif -%}
{#- Pre-compute bind-mount list with tilde expansion -#}
{%- set _expanded_mounts = [] -%}
{%- for bm in catalog_entry.get('bind_mounts', []) -%}
{%- set _host = _tilde_expand(bm.host, _home) | trim -%}
{%- do _expanded_mounts.append({'host': _host, 'container': bm.container, 'mode': bm.mode}) -%}
{%- endfor -%}

# container_service({{ name }}): Quadlet unit file ({{ 'user' if user_scope else 'system' }} scope)
{{ name }}_container:
  file.managed:
    - name: {{ _quadlet_path }}
    - source: {{ _quadlet_source }}
    - template: jinja
    - mode: '0644'
    - makedirs: True
{%- if user_scope %}
    - user: {{ _user }}
    - group: {{ _user }}
{%- endif %}
    - context:
        catalog_entry: {{ catalog_entry | tojson }}
        image: {{ _full_image }}
        expanded_mounts: {{ _expanded_mounts | tojson }}
        user_scope: {{ user_scope | tojson }}

# container_service({{ name }}): digest-pinned image pull (idempotent via `podman image exists`)
{{ name }}_image_pull:
  cmd.run:
    - name: podman pull {{ _full_image }}
    - unless: podman image exists {{ _full_image }}
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- if user_scope %}
    - runas: {{ _user }}
    - env:
{%- for entry in _systemctl_env %}
      - {{ entry }}
{%- endfor %}
{%- endif %}
{%- if requires %}
    - require:
{%- for req in requires %}
      - {{ req }}
{%- endfor %}
{%- endif %}

# container_service({{ name }}): daemon-reload so Quadlet regenerates the systemd unit
{{ name }}_daemon_reload:
  cmd.run:
    - name: systemctl {% if user_scope %}--user {% endif %}daemon-reload
{%- if user_scope %}
    - runas: {{ _user }}
    - env:
{%- for entry in _systemctl_env %}
      - {{ entry }}
{%- endfor %}
{%- endif %}
    - onchanges:
      - file: {{ name }}_container

{%- if not _manual_start %}

# container_service({{ name }}): enable + reset_failed + running + healthcheck
# (targeting systemd unit "{{ _quadlet_name }}.service" — may differ from state
# ID prefix when quadlet_unit_name is overridden for blue/green coexistence)
{{ name }}_enabled:
{%- if user_scope %}
  cmd.run:
    - name: systemctl --user is-enabled {{ _quadlet_name }}.service >/dev/null 2>&1 || systemctl --user enable {{ _quadlet_name }}.service
    - runas: {{ _user }}
    - env:
{%- for entry in _systemctl_env %}
      - {{ entry }}
{%- endfor %}
    - unless: systemctl --user is-enabled {{ _quadlet_name }}.service >/dev/null 2>&1
    - require:
      - cmd: {{ name }}_image_pull
      - cmd: {{ name }}_daemon_reload
{%- else %}
  service.enabled:
    - name: {{ _quadlet_name }}
    - require:
      - cmd: {{ name }}_image_pull
      - cmd: {{ name }}_daemon_reload
{%- endif %}

{{ name }}_reset_failed:
  cmd.run:
    - name: systemctl {% if user_scope %}--user {% endif %}reset-failed {{ _quadlet_name }} 2>/dev/null; true
    - onlyif: systemctl {% if user_scope %}--user {% endif %}is-failed {{ _quadlet_name }}
{%- if user_scope %}
    - runas: {{ _user }}
    - env:
{%- for entry in _systemctl_env %}
      - {{ entry }}
{%- endfor %}
{%- endif %}
    - require:
{%- if user_scope %}
      - cmd: {{ name }}_enabled
{%- else %}
      - service: {{ name }}_enabled
{%- endif %}

{{ name }}_running:
{%- if user_scope %}
  cmd.run:
    - name: systemctl --user is-active {{ _quadlet_name }}.service >/dev/null 2>&1 || systemctl --user start {{ _quadlet_name }}.service
    - runas: {{ _user }}
    - env:
{%- for entry in _systemctl_env %}
      - {{ entry }}
{%- endfor %}
    - unless: systemctl --user is-active {{ _quadlet_name }}.service >/dev/null 2>&1
{%- else %}
  service.running:
    - name: {{ _quadlet_name }}
{%- endif %}
    - watch:
      - file: {{ name }}_container
{%- for w in (watch or []) %}
      - {{ w }}
{%- endfor %}
    - require:
{%- if user_scope %}
      - cmd: {{ name }}_enabled
{%- else %}
      - service: {{ name }}_enabled
{%- endif %}
      - cmd: {{ name }}_reset_failed
{%- endif %}

{#- Post-start healthcheck via service_with_healthcheck (skipped for manual_start).
    Targets _quadlet_name systemd unit (may differ from logical name for
    blue/green cases) but preserves state ID prefix based on logical name. -#}
{%- if not _manual_start %}

{{ service_with_healthcheck(name ~ '_healthcheck', _quadlet_name, catalog={_quadlet_name: catalog_entry}, requires=['cmd: ' ~ name ~ '_running']) }}
{%- endif %}

{#- Bounded native-package teardown after rollback window close (research Decision 5, FR-006) -#}
{%- if _packages %}

# container_service({{ name }}): bounded native package teardown after 7-day rollback window
{{ name }}_native_teardown:
  pkg.removed:
    - pkgs:
{%- for p in _packages.split() %}
      - {{ p }}
{%- endfor %}
{%- if _cutover_date %}
    - onlyif: >-
        test "$(( ( $(date +%s) - $(date -d '{{ _cutover_date }}' +%s) ) / 86400 ))" -ge 7
{%- else %}
    - onlyif: /bin/false    # cutover_date is null; teardown not yet armed
{%- endif %}
    - require:
{%- if _manual_start %}
      - cmd: {{ name }}_image_pull
{%- else %}
      - cmd: {{ name }}_healthcheck
{%- endif %}
{%- endif %}
{%- endif %}{# close "all preconditions passed" else (Level 4) #}
{%- endif %}{# close "digest is none" if (Level 3) #}
{%- endif %}{# close "image key found in registry" else (Level 2) #}
{%- endif %}{# close "containerized flag true" else (Level 1) #}
{%- endmacro -%}
