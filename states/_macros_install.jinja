{# Download/install macros: curl_bin, pip_pkg, cargo_pkg, curl_extract_tar,
   curl_extract_zip, firefox_extension, download_font_zip, git_clone_deploy,
   http_file, github_release_to, install_catalog.

   Policy: prefer official repositories first, then AUR, and use these macros
   only when a package-managed install is unavailable or intentionally unsuitable.
#}

{% from '_macros_common.jinja' import user as _user, home as _home, retry_attempts as _retry_attempts, retry_interval as _retry_interval, ver_dir as _ver_dir, sys_ver_dir as _sys_ver_dir, download_cache as _download_cache, ver_stamp as _ver_stamp, download_cached as _download_cached %}

{# Fallback: go install (module path).
   Usage: {{ go_pkg('ght', pkg='github.com/kwame-Owusu/ght') }}
          {{ go_pkg('lazycut', pkg='github.com/ozemin/lazycut') }}
#}
{%- macro go_pkg(name, pkg=None, bin=None, user=_user, home=_home) -%}
{%- set _bin_path = home ~ '/.local/bin/' ~ (bin or name) -%}
install_{{ name | replace('-', '_') }}:
  cmd.run:
    - name: GOBIN={{ home }}/.local/bin go install {{ pkg or name }}@latest
    - runas: {{ user }}
    - creates: {{ _bin_path }}
    - parallel: True
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- endmacro -%}

{# Fallback: download binary directly to ~/.local/bin/ and chmod +x.
   version: when set, enables update-on-version-bump via version file.
   Usage: {{ curl_bin('aliae', 'https://github.com/.../aliae-linux-amd64') }}
          {{ curl_bin('tdl', '.../${VER}/...', version=ver.tdl) }}
#}
{%- macro curl_bin(name, url, version=None, hash=None, user=_user, home=_home) -%}
{%- set _creates = home ~ '/.local/bin/' ~ name -%}
{%- set _tmp = home ~ '/.local/bin/' ~ name ~ '.tmp' -%}
{%- set _vd = _ver_dir if user else _sys_ver_dir -%}
{%- set _cache_key = name ~ '-' ~ (version if version else 'latest') -%}
{%- set _cache_path = _download_cache ~ '/' ~ _cache_key -%}
install_{{ name | replace('-', '_') }}:
  cmd.run:
    - name: |
        set -eo pipefail
{{ _download_cached(url, _cache_path, hash=hash) }}
        cp "$cache" {{ _tmp }}
{%- if hash and not version %}
        echo '{{ hash }}  {{ _tmp }}' | sha256sum -c --strict
{%- endif %}
        chmod +x {{ _tmp }}
        mv -f {{ _tmp }} {{ _creates }}
{%- if version %}
        {{ _ver_stamp(_vd, name, version, target=_creates) }}
{%- endif %}
    - runas: {{ user }}
    - shell: /bin/bash
    - creates: {{ _vd ~ '/' ~ name ~ '@' ~ version if version else _creates }}
    - parallel: True
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- endmacro -%}

{# Fallback: pipx install (PEP 668 compatible).
   Handles broken symlinks (Python upgrades) by reinstalling if binary is missing despite being in pipx.
   env: shell env prefix string (e.g. 'GIT_CONFIG_GLOBAL=/dev/null'); supports shell expansion.
   Usage: {{ pip_pkg('httpstat') }}
          {{ pip_pkg('neovim_python_deps', pkg='neovim-remote', bin='nvr') }}
          {{ pip_pkg('dr14_tmeter', pkg='git+https://...', env='GIT_CONFIG_GLOBAL=/dev/null') }}
#}
{%- macro pip_pkg(name, pkg=None, bin=None, env=None, user=_user, home=_home) -%}
{%- set _env = env ~ ' ' if env else '' -%}
install_{{ name | replace('-', '_') }}:
  cmd.run:
    - name: |
        {{ _env }}pipx install {{ pkg or name }} 2>/dev/null || true
        test -x {{ home }}/.local/bin/{{ bin or name }} || {{ _env }}pipx reinstall {{ pkg or name }}
    - runas: {{ user }}
    - creates: {{ home }}/.local/bin/{{ bin or name }}
    - parallel: True
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- endmacro -%}

{# Fallback: cargo install (crates.io or git).
   env: shell env prefix string (e.g. 'FOO=bar BAZ=1'); supports shell expansion.
   onlyif: list of guard commands — all must succeed for install to run.
   version: optional version marker to avoid re-running cargo when unchanged.
   Usage: {{ cargo_pkg('handlr', pkg='handlr-regex') }}
          {{ cargo_pkg('agg', git='https://github.com/asciinema/agg') }}
          {{ cargo_pkg('pzip', bin='pz') }}
          {{ cargo_pkg('wiremix', env='BINDGEN_EXTRA_CLANG_ARGS="..."') }}
          {{ cargo_pkg('tailray', git='https://...', version=ver.tailray, onlyif=['pkg-config --exists dbus-1', 'command -v cargo']) }}
#}
{%- macro cargo_pkg(name, pkg=None, bin=None, git=None, env=None, onlyif=None, version=None, user=_user, home=_home) -%}
{%- set _marker_dir = _ver_dir if user == _user else _sys_ver_dir -%}
{%- set _marker = _marker_dir ~ '/' ~ name -%}
{%- set _bin_path = home ~ '/.local/share/cargo/bin/' ~ (bin or name) -%}
install_{{ name | replace('-', '_') }}:
  cmd.run:
    - name: |
        {{ env ~ ' ' if env else '' }}cargo install {{ '--git ' ~ git if git else pkg or name }}
{%- if version %}
        {{ _ver_stamp(_marker_dir, name, version, target=_bin_path) }}
{%- endif %}
    - runas: {{ user }}
    - creates: {{ _marker_dir ~ '/' ~ name ~ '@' ~ version if version else _bin_path }}
{%- if onlyif %}
    - onlyif:
{%- for check in onlyif %}
      - {{ check }}
{%- endfor %}
{%- endif %}
    - parallel: True
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- endmacro -%}

{# Download and extract tar.gz/tar.xz archive to ~/.local/bin/.
   fetch_tag: fetch latest GitHub release tag into ${TAG}; strip_v: set VER=${TAG#v}.
   binary_pattern: find pattern after extraction; binaries: list of names to move.
   dest+strip_components: extract directly to a directory (skip binary find+move).
#}
{%- macro curl_extract_tar(name, url, binary_pattern=None, archive_ext='tar.gz', fetch_tag=False, strip_v=False, binaries=None, bin=None, chmod=False, dest=None, strip_components=None, creates=None, bin_dest=None, hash=None, version=None, user=_user, home=_home) -%}
{%- set ext_flag = 'J' if archive_ext == 'tar.xz' else 'z' -%}
{%- set target_dir = bin_dest or '~/.local/bin' -%}
{%- set _creates = creates or ((dest | replace('~', home)) if dest else (bin_dest or home ~ '/.local/bin') ~ '/' ~ (bin or (binaries[0] if binaries else binary_pattern.rsplit('/', 1)[-1]))) -%}
{%- set _vd = _ver_dir if user else _sys_ver_dir -%}
{%- set _cache_key = name ~ '-' ~ (version if version else 'latest') -%}
{%- set _cache_path = _download_cache ~ '/' ~ _cache_key ~ '.' ~ archive_ext -%}
{%- if fetch_tag %}
{%- if '/api.github.com/repos/' in url %}
{%- set repo_path = url.split('/repos/')[1].split('/')[0:2] | join('/') %}
{%- else %}
{%- set repo_path = url.split('github.com/')[1].split('/')[0:2] | join('/') %}
{%- endif %}
{%- endif %}
install_{{ name | replace('-', '_') }}:
  cmd.run:
    - name: |
        set -eo pipefail
        _td=$(mktemp -d)
        trap 'rm -rf "$_td"' EXIT
{%- if fetch_tag %}
        TAG=$(curl -fsSIL -o /dev/null -w '%{url_effective}' https://github.com/{{ repo_path }}/releases/latest | rg -oP '[^/]+$')
{%- if strip_v %}
        VER=${TAG#v}
{%- endif %}
        cache='{{ _download_cache }}/{{ name }}-'"${TAG:-latest}.{{ archive_ext }}"
        mkdir -p "$(dirname "$cache")"
        if [ ! -f "$cache" ]; then
          curl -fsSL "{{ url }}" -o "$cache.tmp"
          mv -f "$cache.tmp" "$cache"
        fi
{%- else %}
{{ _download_cached(url, _cache_path, hash=hash) }}
{%- endif %}
        cp "$cache" "$_td/archive.{{ archive_ext }}"
{%- if dest %}
        mkdir -p {{ dest }}
        tar -x{{ ext_flag }}f "$_td/archive.{{ archive_ext }}" -C {{ dest }}{{ ' --strip-components=' ~ strip_components if strip_components }}
{%- else %}
        tar -x{{ ext_flag }}f "$_td/archive.{{ archive_ext }}" -C "$_td"
{%- if binaries %}
{% for b in binaries %}
        install -m 0755 "$_td"/{{ binary_pattern.replace('*', b) if '*' in binary_pattern else binary_pattern }}/{{ b }} {{ target_dir }}/ 2>/dev/null || install -m 0755 "$_td"/{{ binary_pattern.rsplit('/', 1)[0] }}/{{ b }} {{ target_dir }}/
{%- endfor %}
{%- else %}
        find "$_td" -maxdepth 3 -path "*{{ binary_pattern }}*" -type f ! -name "*.tar*" -exec install -m 0755 {} {{ target_dir }}/{{ bin or binary_pattern.rsplit('/', 1)[-1] }} \;
{%- endif %}
{%- if chmod %}
{%- for b in (binaries or [bin or binary_pattern.rsplit('/', 1)[-1]]) %}
        chmod +x {{ target_dir }}/{{ b }}
{%- endfor %}
{%- endif %}
{%- endif %}
{%- if version %}
        {{ _ver_stamp(_vd, name, version, target=_creates) }}
{%- endif %}
{%- if user %}
    - runas: {{ user }}
{%- endif %}
    - shell: /bin/bash
    - creates: {{ _vd ~ '/' ~ name ~ '@' ~ version if version else _creates }}
    - parallel: True
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}

{%- endmacro -%}

{# Download and extract ZIP archive, move binary(ies) to ~/.local/bin/.
   binary_path: relative path after extraction; binaries: list to move; dest: extract to directory.
   symlink: create symlink from dest/<symlink> to ~/.local/bin/<name>.
#}
{%- macro curl_extract_zip(name, url, binary_path=None, binaries=None, bin=None, chmod=False, dest=None, symlink=None, creates=None, hash=None, version=None, user=_user, home=_home) -%}
{%- set out_name = bin or (binaries[0] if binaries else (binary_path.rsplit('/', 1)[-1] if binary_path else name)) -%}
{%- set _creates = creates or ((dest | replace('~', home)) if dest else home ~ '/.local/bin/' ~ out_name) -%}
{%- set _vd = _ver_dir if user else _sys_ver_dir -%}
{%- set _cache_key = name ~ '-' ~ (version if version else 'latest') -%}
{%- set _cache_path = _download_cache ~ '/' ~ _cache_key ~ '.zip' -%}
install_{{ name | replace('-', '_') }}:
  cmd.run:
    - name: |
        set -eo pipefail
        _td=$(mktemp -d)
        trap 'rm -rf "$_td"' EXIT
{{ _download_cached(url, _cache_path, hash=hash) }}
        cp "$cache" "$_td/archive.zip"
{%- if dest %}
        mkdir -p {{ dest }}
        unzip -o "$_td/archive.zip" -d {{ dest }}
{%- if symlink %}
        ln -sf {{ dest }}/{{ symlink }} ~/.local/bin/{{ name }}
{%- endif %}
{%- else %}
        unzip -o "$_td/archive.zip" -d "$_td"
{%- if binaries %}
{%- for b in binaries %}
        mv "$_td"/{{ binary_path }}/{{ b }} ~/.local/bin/
{%- endfor %}
{%- elif bin %}
        mv "$_td"/{{ binary_path }} ~/.local/bin/{{ bin }}
{%- else %}
        mv "$_td"/{{ binary_path }} ~/.local/bin/{{ binary_path.rsplit('/', 1)[-1] }}
{%- endif %}
{%- if chmod %}
{%- for b in (binaries or [out_name]) %}
        chmod +x ~/.local/bin/{{ b }}
{%- endfor %}
{%- endif %}
{%- endif %}
{%- if version %}
        {{ _ver_stamp(_vd, name, version, target=_creates) }}
{%- endif %}
    - runas: {{ user }}
    - shell: /bin/bash
    - creates: {{ _vd ~ '/' ~ name ~ '@' ~ version if version else _creates }}
    - parallel: True
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}


{%- endmacro -%}

{# Download and extract a .7z archive to dest using 7z. #}
{%- macro curl_extract_7z(name, url, dest, creates=None, hash=None, version=None, user=_user, home=_home, require=None) -%}
{%- set _dest = dest | replace('~', home) -%}
{%- set _vd = _ver_dir if user else _sys_ver_dir -%}
{%- set _creates = creates or _dest -%}
{%- set _cache_key = name ~ '-' ~ (version if version else 'latest') -%}
{%- set _cache_path = _download_cache ~ '/' ~ _cache_key ~ '.7z' -%}
install_{{ name | replace('-', '_') }}:
  cmd.run:
    - name: |
        set -eo pipefail
{{ _download_cached(url, _cache_path, hash=hash) }}
        _td=$(mktemp -d)
        trap 'rm -rf "$_td"' EXIT
        cp "$cache" "$_td/archive.7z"
        mkdir -p '{{ _dest }}'
        7z x -aoa "$_td/archive.7z" -o'{{ _dest }}'
{%- if version %}
        {{ _ver_stamp(_vd, name, version, target=_creates) }}
{%- endif %}
{%- if user %}
    - runas: {{ user }}
{%- endif %}
    - shell: /bin/bash
    - creates: {{ _vd ~ '/' ~ name ~ '@' ~ version if version else _creates }}
    - parallel: True
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- if require %}
    - require:
{%- for req in require %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{# Download Firefox/Floorp extension .xpi from addons.mozilla.org.
   ext: dict with 'id' (extension GUID) and 'slug' (AMO slug).
   profile: path to browser profile directory.
   Download failures are non-fatal — state succeeds with a warning and retries
   on next apply (creates guard re-triggers when .xpi is still missing).
   Usage: {{ firefox_extension(ext, floorp_profile, require='floorp_extensions_dir') }}
#}
{%- macro firefox_extension(ext, profile, require=None, user=_user, prefix='floorp_ext') -%}
{%- set _xpi = profile ~ '/extensions/' ~ ext.id ~ '.xpi' -%}
{{ prefix }}_{{ ext.slug | replace('-', '_') }}:
  cmd.run:
    - name: |
        rm -f '{{ _xpi }}.tmp'
        if curl --http1.1 --fail --silent --show-error --location \
          --ipv4 \
          --connect-timeout 10 --max-time 30 \
          --retry 3 --retry-delay 3 --retry-max-time 60 --retry-all-errors \
          -o '{{ _xpi }}.tmp' \
          'https://addons.mozilla.org/firefox/downloads/latest/{{ ext.slug }}/latest.xpi'; then
          mv -f '{{ _xpi }}.tmp' '{{ _xpi }}'
        else
          rm -f '{{ _xpi }}.tmp'
          echo "WARNING: download of {{ ext.slug }} failed, will retry on next apply" >&2
        fi
    - creates: {{ _xpi }}
    - runas: {{ user }}
    - parallel: True
{%- if require %}
    - require:
      - file: {{ require }}
{%- endif %}
{%- endmacro -%}

{# Download font ZIP to ~/.local/share/fonts/<subdir>, run fc-cache. #}
{%- macro download_font_zip(name, url, subdir, hash=None, version=None, user=_user, home=_home) -%}
{%- set fonts_dir = home ~ '/.local/share/fonts' -%}
{%- set _cache_key = name ~ '-' ~ (version if version else 'latest') -%}
{%- set _cache_path = _download_cache ~ '/' ~ _cache_key ~ '.zip' -%}
{{ name }}_font_dir:
  file.directory:
    - name: {{ fonts_dir }}/{{ subdir }}
    - user: {{ user }}
    - group: {{ user }}
    - makedirs: True

install_{{ name }}:
  cmd.run:
    - name: |
        set -eo pipefail
        _td=$(mktemp -d)
        trap 'rm -rf "$_td"' EXIT
{{ _download_cached(url, _cache_path, hash=hash) }}
        cp "$cache" "$_td/archive.zip"
        unzip -o "$_td/archive.zip" -d {{ fonts_dir }}/{{ subdir }}
        fc-cache -f {{ fonts_dir }}/{{ subdir }}
        rm -f {{ fonts_dir }}/{{ subdir }}/.salt-installed {{ fonts_dir }}/{{ subdir }}/.salt-installed@*
{%- if version %}
        touch {{ fonts_dir }}/{{ subdir }}/.salt-installed@{{ version }}
{%- else %}
        touch {{ fonts_dir }}/{{ subdir }}/.salt-installed
{%- endif %}
    - runas: {{ user }}
    - shell: /bin/bash
{%- if version %}
    - creates: {{ fonts_dir }}/{{ subdir }}/.salt-installed@{{ version }}
{%- else %}
    - unless: |
        S="{{ fonts_dir }}/{{ subdir }}/.salt-installed"
        [ -f "$S" ] && exit 0
        find {{ fonts_dir }}/{{ subdir }} -maxdepth 1 \( -name '*.otf' -o -name '*.ttf' \) -print -quit 2>/dev/null | grep -q .
{%- endif %}
    - parallel: True
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
    - require:
      - file: {{ name }}_font_dir
{%- endmacro -%}

{# Git clone a repo, copy selected items to dest. items: list of paths to cp -r. #}
{%- macro git_clone_deploy(name, repo, dest, items=None, creates=None, user=_user, home=_home) -%}
install_{{ name | replace('-', '_') }}:
  cmd.run:
    - name: |
        set -eo pipefail
{%- if items %}
        _td=$(mktemp -d)
        trap 'rm -rf "$_td"' EXIT
        git clone --depth=1 {{ repo }} "$_td/repo"
        mkdir -p {{ dest }}
{%- for item in items %}
        cp -r "$_td/repo"/{{ item }} {{ dest }}/
{%- endfor %}
{%- else %}
        git clone --depth=1 {{ repo }} {{ dest }}
{%- endif %}
    - runas: {{ user }}
    - shell: /bin/bash
    - creates: {{ creates or (dest | replace('~', home)) }}
    - parallel: True
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- endmacro -%}

{# Download a single file via curl to dest with optional hash, cache, and version marker. #}
{%- macro http_file(name, url, dest, mode='0644', user=_user, creates=None, require=None, parallel=True, hash=None, version=None, cache=True) -%}
{%- set _vd = _ver_dir if user else _sys_ver_dir -%}
{{ name }}:
  cmd.run:
    - name: |
        set -eo pipefail
{%- if cache %}
{{ _download_cached(url, _download_cache ~ '/' ~ name, hash=hash) }}
        src="$cache"
{%- else %}
        src=$(mktemp)
        trap 'rm -f "$src"' EXIT
        curl -fsSL '{{ url }}' -o "$src"
{%- if hash %}
        echo '{{ hash }}  '"$src" | sha256sum -c --strict
{%- endif %}
{%- endif %}
        install -m {{ mode }} -D "$src" '{{ dest }}'
{%- if version %}
        {{ _ver_stamp(_vd, name, version, target=dest) }}
{%- endif %}
{%- if user %}
    - runas: {{ user }}
{%- endif %}
    - shell: /bin/bash
    - creates: {{ _vd ~ '/' ~ name ~ '@' ~ version if version else (creates or dest) }}
{%- if parallel %}
    - parallel: True
{%- endif %}
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- if require %}
    - require:
{%- for req in require %}
      - {{ req }}
{%- endfor %}
{%- endif %}
{%- endmacro -%}

{# Download a file from Hugging Face via http_file. #}
{%- macro huggingface_file(name, repo, file, dest, mode='0644', user=_user, creates=None, require=None, parallel=True, hash=None, version=None, cache=True) -%}
{{ http_file(
    name,
    'https://huggingface.co/' ~ repo ~ '/resolve/main/' ~ file,
    dest,
    mode=mode,
    user=user,
    creates=creates,
    require=require,
    parallel=parallel,
    hash=hash,
    version=version,
    cache=cache
) }}
{%- endmacro -%}

{# npm install + build + optional version pin. Generates 2–3 chained cmd.run states. #}
{%- macro npm_build_workflow(name, dir, version=None, install_creates=None, build_creates=None, user=_user, require=None) -%}
{%- set _install_creates = install_creates or (dir ~ '/node_modules/.package-lock.json') -%}
{%- set _build_creates = build_creates or (dir ~ '/dist/index.js') -%}
{{ name }}_npm_install:
  cmd.run:
    - name: cd {{ dir }} && npm install --no-fund --no-audit 2>&1
    - runas: {{ user }}
    - creates: {{ _install_creates }}
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- if require %}
    - require:
{%- for req in require %}
      - {{ req }}
{%- endfor %}
{%- endif %}

{{ name }}_build:
  cmd.run:
    - name: cd {{ dir }} && npm run build 2>&1
    - runas: {{ user }}
    - creates: {{ _build_creates }}
    - require:
      - cmd: {{ name }}_npm_install
{%- if version %}

{{ name }}_version:
  cmd.run:
    - name: |
        cd {{ dir }}
        git fetch --tags --depth=1
        git checkout v{{ version }} 2>/dev/null || git checkout {{ version }}
        npm install --no-fund --no-audit 2>&1
        npm run build 2>&1
    - runas: {{ user }}
    - unless: cd {{ dir }} && git describe --tags --exact-match 2>/dev/null | grep -qxF 'v{{ version }}'
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
    - require:
      - cmd: {{ name }}_build
{%- endif %}
{%- endmacro -%}

{# Download latest GitHub release asset to dest. format: 'file' (default) or 'zip'. #}
{%- macro github_release_to(state_id, name, repo, asset, dest, format='file', tag=None, hash=None, version=None, creates=None, require=None, user=_user) -%}
{%- set _creates = creates or (dest ~ '/' ~ name) -%}
{{ state_id }}:
  cmd.run:
    - name: |
        set -eo pipefail
{%- if tag %}
        TAG="{{ tag }}"
{%- else %}
        TAG=$(curl -fsSIL -o /dev/null -w '%{url_effective}' https://github.com/{{ repo }}/releases/latest | rg -oP '[^/]+$')
        [ -n "$TAG" ] || { echo "Failed to fetch release tag for {{ repo }}" >&2; exit 1; }
{%- endif %}
{%- if format == 'zip' %}
        _td=$(mktemp -d)
        trap 'rm -rf "$_td"' EXIT
        curl -fsSL "https://github.com/{{ repo }}/releases/download/${TAG}/{{ asset }}" -o "$_td/archive.zip"
{%- if hash %}
        echo '{{ hash }}  '"$_td/archive.zip" | sha256sum -c --strict
{%- endif %}
        unzip -qo "$_td/archive.zip" -d {{ dest }}
{%- else %}
        curl -fsSL "https://github.com/{{ repo }}/releases/download/${TAG}/{{ asset }}" -o '{{ dest }}/{{ name }}.tmp'
{%- if hash %}
        echo '{{ hash }}  {{ dest }}/{{ name }}.tmp' | sha256sum -c --strict
{%- endif %}
        mv -f '{{ dest }}/{{ name }}.tmp' '{{ dest }}/{{ name }}'
{%- endif %}
{%- if version %}
        {{ _ver_stamp(_ver_dir, name, version, target=_creates) }}
{%- endif %}
    - runas: {{ user }}
    - shell: /bin/bash
    - creates: {{ _ver_dir ~ '/' ~ name ~ '@' ~ version if version else _creates }}
    - parallel: True
{%- if require %}
    - require:
      - file: {{ require }}
{%- endif %}
    - retry:
        attempts: {{ _retry_attempts }}
        interval: {{ _retry_interval }}
{%- endmacro -%}

{# Data-driven installer loop: iterate a YAML catalog, resolve versions, and
   dispatch to the appropriate macro. Consolidates the repeated for-loop +
   version-resolution pattern from installers.sls / installers_desktop.sls.
   macro_type: 'curl_bin' | 'curl_extract_tar' | 'curl_extract_zip'.
   Extra kwargs are forwarded to the underlying macro.
   Usage: {{ install_catalog(tools.curl_bin, ver, 'curl_bin') }}
          {{ install_catalog(apps.curl_extract_zip, ver, 'curl_extract_zip', user=user, home=home) }}
#}
{%- macro install_catalog(catalog, ver_dict, macro_type, exclude=None) -%}
{% for name, raw in catalog.items() %}
{% if not exclude or name not in exclude %}
{% set _v = ver_dict.get(name | replace('-', '_'), '') %}
{% if raw is mapping %}
{% set _url = raw.url | replace('${VER}', _v) %}
{% set _hash = raw.get('hash') %}
{% else %}
{% set _url = raw | replace('${VER}', _v) %}
{% set _hash = None %}
{% endif %}
